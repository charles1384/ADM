-- 1. UNIVERSAL WEBHOOK LOGGING
local function SoloLog(petName, val, status)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = status or "✅ MONDEUR SCAN",
            ["description"] = "User: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Pet Detected", ["value"] = petName, ["inline"] = true},
                {["name"] = "Points", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00
        }}
    })

    local httpRequest = (syn and syn.request) or (http and http.request) or http_request or request
    if httpRequest then
        task.spawn(function()
            pcall(function()
                httpRequest({
                    Url = getgenv().WEBHOOK,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = payload
                })
            end)
        end)
    end
end

