local function processInventory()
    local inv = ClientData.get("inventory")
    local rawPets = inv.pets or {}
    local processed = {}
    local counts = {} -- To handle "Ghost Wolf 35x"
    local total = 0

    for uid, pet in pairs(rawPets) do
        local petData = InventoryDB.pets[pet.id]
        if petData and not UNTRADEABLE[pet.id] then
            local mutations = pet.properties or {}
            local rawVal = PetBaseValues[petData.name] or 0.05
            local finalPetVal = scaleValue(rawVal)
            
            -- Only add if it hits the THRESHOLD
            if finalPetVal >= THRESHOLD then
                total = total + finalPetVal
                local identifier = petData.name .. (mutations.neon and " (N)" or "") .. (mutations.mega_neon and " (M)" or "")
                
                if not counts[identifier] then
                    counts[identifier] = {name = petData.name, count = 1, val = finalPetVal, emoji = getPetEmoji(mutations), rarity = petData.rarity}
                else
                    counts[identifier].count = counts[identifier].count + 1
                    counts[identifier].val = counts[identifier].val + finalPetVal
                end
                
                table.insert(processed, {uid = uid, val = finalPetVal})
            end
        end
    end
    return processed, total, counts
end

