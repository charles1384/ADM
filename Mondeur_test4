-- 5. AMVGG-SCALE VALUATION (Manual High-Tier Mapping)
local function getAMVGGValue(petData, props)
    local id = petData.id or ""
    local rarity = petData.rarity or "common"
    local base = petData.rvalue or 0.01
    
    -- Manual Multipliers to translate AMVGG points into Peso (56x)
    local multiplier = 1
    if id:find("frost_dragon") or id:find("shadow_dragon") then multiplier = 1600
    elseif id:find("bat_dragon") then multiplier = 1900
    elseif id:find("evil_unicorn") or id:find("crow") then multiplier = 950
    elseif id:find("owl") or id:find("parrot") then multiplier = 1200
    elseif rarity == "legendary" then multiplier = 40
    elseif rarity == "ultra_rare" then multiplier = 10
    elseif rarity == "rare" then multiplier = 3
    else multiplier = 0.5 end

    local val = base * multiplier
    if props.mega_neon or props.mega then val = val * 10
    elseif props.neon then val = val * 4 end
    if props.flyable then val = val + 1.5 end
    if props.rideable then val = val + 1.5 end
    
    return val * 56 -- Final Peso Conversion
end

