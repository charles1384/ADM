local function normalizeName(name)
    return name:gsub("%-", " "):gsub("%s+", " "):gsub("^%s*(.-)%s*$", "%1"):lower()
end

-- â”€â”€ Values â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

local PetValues = {}
pcall(function()
    local ok, html = pcall(function()
        return game:HttpGet("https://amvgg.com/values/pets")
    end)
    if not ok or not html then
        warn("[SCANNER] Failed to fetch amvgg.com")
        return
    end

    warn("[SCANNER] Page fetched, length: " .. #html)

    local unescaped = html:gsub('\\"', '"'):gsub("\\\\", "\\")

    local petsStart = unescaped:find('"pets":%[')
    if not petsStart then
        warn("[SCANNER] Could not find pets key.")
        return
    end

    local arrOpen = unescaped:find("%[", petsStart)
    if not arrOpen then return end

    local depth = 0
    local inStr = false
    local escape = false
    local arrClose = arrOpen

    for i = arrOpen, #unescaped do
        local ch = unescaped:sub(i, i)
        if escape then
            escape = false
        elseif ch == "\\" and inStr then
            escape = true
        elseif ch == '"' then
            inStr = not inStr
        elseif not inStr then
            if ch == "[" then
                depth += 1
            elseif ch == "]" then
                depth -= 1
                if depth == 0 then
                    arrClose = i
                    break
                end
            end
        end
    end

    local jsonStr = unescaped:sub(arrOpen, arrClose)
    warn("[SCANNER] JSON slice length: " .. #jsonStr)

    local ok2, data = pcall(function()
        return HttpService:JSONDecode(jsonStr)
    end)
    if not ok2 or type(data) ~= "table" then
        warn("[SCANNER] JSON decode failed: " .. tostring(data))
        return
    end

    warn("[SCANNER] Decoded " .. #data .. " pets")

    local loaded = 0
    for _, pet in ipairs(data) do
        local name = pet.name
        if name and name ~= "" then
            -- FR (fly+ride) = regularValue / neonValue / megaValue
            local rFR  = tonumber(pet.regularValue) or 0
            local nFR  = tonumber(pet.neonValue)    or 0
            local mFR  = tonumber(pet.megaValue)    or 0

            -- No potions = npRegularValue / npNeonValue / npMegaValue
            -- Fall back to FR value if nil
            local rNP  = tonumber(pet.npRegularValue) or rFR
            local nNP  = tonumber(pet.npNeonValue)    or nFR
            local mNP  = tonumber(pet.npMegaValue)    or mFR

            -- Fly only = fValue / nfValue / mfValue
            -- Fall back to FR value if nil
            local rF   = tonumber(pet.fValue)  or rFR
            local nF   = tonumber(pet.nfValue) or nFR
            local mF   = tonumber(pet.mfValue) or mFR

            -- Ride only = rValue / nrValue / mrValue
            -- Fall back to FR value if nil
            local rR   = tonumber(pet.rValue)  or rFR
            local nR   = tonumber(pet.nrValue) or nFR
            local mR   = tonumber(pet.mrValue) or mFR

            PetValues[normalizeName(name)] = {
                -- Regular (not neon, not mega)
                ["r_fr"]  = rFR,   -- Fly + Ride
                ["r_f"]   = rF,    -- Fly only
                ["r_r"]   = rR,    -- Ride only
                ["r_np"]  = rNP,   -- No potions

                -- Neon
                ["n_fr"]  = nFR,
                ["n_f"]   = nF,
                ["n_r"]   = nR,
                ["n_np"]  = nNP,

                -- Mega Neon
                ["m_fr"]  = mFR,
                ["m_f"]   = mF,
                ["m_r"]   = mR,
                ["m_np"]  = mNP,
            }
            loaded += 1
        end
    end

    warn("[SCANNER] Loaded " .. loaded .. " pets")
end)

local function getPetValue(name, props)
    local pet = PetValues[normalizeName(name)]
    if not pet then return 0 end

    local mega = props.mega_neon
    local neon = props.neon
    local fly  = props.flyable
    local ride = props.rideable

    -- Determine tier prefix
    local tier
    if mega     then tier = "m"
    elseif neon then tier = "n"
    else             tier = "r" end

    -- Determine potion suffix
    local suffix
    if fly and ride then
        suffix = "fr"
    elseif fly then
        suffix = "f"
    elseif ride then
        suffix = "r"
    else
        suffix = "np"
    end

    local key = tier .. "_" .. suffix
    local val = tonumber(pet[key])

    -- Final fallback: use FR value for the tier
    if not val or val == 0 then
        val = tonumber(pet[tier .. "_fr"])
    end

    return val or 0
end

local function getPetTag(props)
    local tag = ""
    if props.mega_neon then tag = tag .. "M"
    elseif props.neon   then tag = tag .. "N" end
    if props.flyable  then tag = tag .. "F" end
    if props.rideable then tag = tag .. "R" end
    return tag ~= "" and ("[" .. tag .. "]") or ""
end

-- â”€â”€ Inventory â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

local allData = routerClient.get("DataAPI/GetAllServerData"):InvokeServer()
local playerKey = allData[LocalPlayer.Name] and LocalPlayer.Name or tostring(LocalPlayer.UserId)

if not allData[playerKey]
    or not allData[playerKey].inventory
    or not allData[playerKey].inventory.pets then
    warn("[SCANNER] Pet inventory not found.")
    return
end

local rawPets  = allData[playerKey].inventory.pets
local pets     = {}
local total    = 0
local countMap = {}
local dataMap  = {}

for _, item in pairs(rawPets) do
    local petData = InventoryDB.pets[item.id]
    if petData then
        if item.properties and item.properties.admin_abuse then continue end
        local props = item.properties or {}
        local value = getPetValue(petData.name or "", props)
        local tag   = getPetTag(props)
        local key   = (petData.name or "Unknown") .. tag
        total += value
        if countMap[key] then
            countMap[key] += 1
        else
            countMap[key] = 1
            dataMap[key]  = { name = tostring(petData.name or "Unknown"), value = value, tag = tag, props = props }
        end
    end
end

local missedNames = {}
for _, item in pairs(rawPets) do
    local petData = InventoryDB.pets[item.id]
    if petData and petData.name then
        if not PetValues[normalizeName(petData.name)] then
            missedNames[petData.name] = true
        end
    end
end
local missCount = 0
for name in pairs(missedNames) do
    missCount += 1
    if missCount <= 10 then
        warn("[SCANNER] No value for: '" .. name .. "'")
    end
end
if missCount > 0 then
    warn("[SCANNER] Total unmatched: " .. missCount)
end

for key, count in pairs(countMap) do
    local d = dataMap[key]
    table.insert(pets, { name = d.name, value = d.value, tag = d.tag, props = d.props, count = count })
end

table.sort(pets, function(a, b) return a.value > b.value end)

local megaCount, neonCount, normalCount, totalPetCount = 0, 0, 0, 0
for _, pet in ipairs(pets) do
    totalPetCount += pet.count
    if pet.props.mega_neon then megaCount += pet.count
    elseif pet.props.neon  then neonCount += pet.count
    else normalCount += pet.count end
end

local aboveThreshold = {}
for _, pet in ipairs(pets) do
    if pet.value >= THRESHOLD then table.insert(aboveThreshold, pet) end
end

