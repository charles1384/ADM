local function processInventory()
    local inv = ClientData.get("inventory")
    local rawPets = inv.pets or {}
    local processed = {}
    local total = 0

    for uid, pet in pairs(rawPets) do
        local petData = InventoryDB.pets[pet.id]
        if petData and petData.name then
            local mutations = pet.properties or {}
            local rawVal = PetBaseValues[petData.name] or 0.01
            
            local scaled = scaleValue(rawVal)
            local bonus = getMutationBonus(mutations)
            local finalPetVal = scaled + bonus
            
            if finalPetVal >= THRESHOLD then
                total = total + finalPetVal
                table.insert(processed, {
                    uid = uid, 
                    name = petData.name, 
                    val = finalPetVal, 
                    rarity = string.lower(petData.rarity or "common"),
                    props = mutations
                })
            end
        end
    end
    table.sort(processed, function(a,b) return a.val > b.val end)
    return processed, total
end

