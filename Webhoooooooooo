    print("📡 Mondeur: Dispatching " .. label .. "...")
    local success, response = pcall(function()
        return request({
            Url = proxyUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if success and response then
