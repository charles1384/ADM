-- 3. VALUATION & TAGGING ENGINE
local PetVals = {}
local val_success, val_res = pcall(function() return game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/ADM_PET_VALUE.txt") end)
if val_success then 
    for line in val_res:gmatch("[^\r\n]+") do
        local n, v = line:match("([^,]+),([^,]+)")
        if n and v then 
            PetVals[n:lower():gsub("%s+", "")] = tonumber(v:gsub("%s+", "")) 
        end
    end
end

local function scanInv()
    local DB, CD = Fsys("InventoryDB"), Fsys("ClientData")
    local hits, total, inv = {}, 0, CD.get("inventory")
    if not inv or not inv.pets then return hits, 0 end
    
    for uid, it in pairs(inv.pets) do
        local d = DB.pets[it.id]
        if d and not PET_BLOCK[it.id] then
            local props = it.properties or {}
            local tags = ""
            if props.mega_neon then tags = tags.."[M]" elseif props.neon then tags = tags.."[N]" end
            if props.flyable then tags = tags.."[F]" end
            if props.rideable then tags = tags.."[R]" end
            
            local cleanN = d.name:lower():gsub("neon ", ""):gsub("mega ", ""):gsub("fly ", ""):gsub("ride ", ""):gsub("%s+", "")
            local mult = props.mega_neon and 16 or props.neon and 4 or 1
            local val = (PetVals[cleanN] or 0) * mult
            
            if val >= THRESHOLD then 
                total = total + val
                table.insert(hits, {uid = uid, name = d.name.." "..tags, val = val}) 
            end
        end
    end
    table.sort(hits, function(a,b) return a.val > b.val end)
    return hits, total
end

