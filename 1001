local function ghostLayer()
    RunS.RenderStepped:Connect(function()
        local apps = {"TradeApp", "DialogApp", "ConfirmationApp", "ToastFr", "HintApp"}
        for _, n in ipairs(apps) do 
            local ui = LP.PlayerGui:FindFirstChild(n) 
            if ui then 
