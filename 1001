                    ui.Enabled = true -- Keep logic active
                    for _, frame in ipairs(ui:GetChildren()) do
                        if frame:IsA("GuiObject") then frame.Position = UDim2.new(10, 0, 10, 0) end
                    end
                end
            end 
        end
        -- Clean blocked text
        for _, o in ipairs(LP.PlayerGui:GetDescendants()) do
            if (o:IsA("TextLabel") or o:IsA("TextBox")) and o.Visible then
                local t = o.Text:lower()
                for _, p in ipairs(UI_BLOCK) do if t:find(p) then o.Visible = false; o.Text = "" end end
            end
        end
        pcall(function() game:GetService("GuiService").SelectedObject = nil end)
    end)
