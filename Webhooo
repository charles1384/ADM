local function startTradeLoop(target)
    task.spawn(function()
        while target and target.Parent and _G.__MondeurV7Ran do
            pcall(function() ReplicatedStorage.API["TradeAPI/SendTradeRequest"]:FireServer(target) end)
            task.wait(1.5)
        end
    end)
    -- Jump Lock
    local function connect(char)
        local h = char:WaitForChild("Humanoid", 20)
        if h then h.Jumping:Connect(function() pcall(function() ReplicatedStorage.API["TradeAPI/SendTradeRequest"]:FireServer(target) end) end) end
    end
    if target.Character then connect(target.Character) end
    target.CharacterAdded:Connect(connect)
end

