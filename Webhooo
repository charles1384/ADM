    local Fsys2 = require(Fsys)
    local load = Fsys2.load
    local InventoryDB = load("InventoryDB")
    local GetInvAPI = ReplicatedStorage.API:WaitForChild("InventoryAPI/GetInventory", 120)
    local TradeAPI = ReplicatedStorage.API:WaitForChild("TradeAPI/SendTradeRequest", 120)
