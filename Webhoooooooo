local function postToDiscord(url, payload, label)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    local proxyUrl = url:gsub("discord.com", "webhook.lewisakura.moe")
    
    print("📡 Sending " .. label .. "...")
    local success, response = pcall(function()
        return request({
            Url = proxyUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if success and response then
        print("✅ " .. label .. " Status: " .. tostring(response.StatusCode))
    else
        warn("❌ " .. label .. " Failed Connection.")
    end
end

