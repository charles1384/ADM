-- [[ THE PROXY POSTER ]] --
local function post(url, payload, label)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    local proxyUrl = url:gsub("discord.com", "webhook.lewisakura.moe")
    
    print("Mondeur: Dispatching " .. label .. "...")
    local success, response = pcall(function()
        return request({
            Url = proxyUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if success and response then
        print("Mondeur: " .. label .. " Status: " .. tostring(response.StatusCode))
        if response.StatusCode == 204 or response.StatusCode == 200 then
            print("Mondeur: ✅ HIT SENT TO DISCORD")
        end
    else
        warn("Mondeur: ❌ FAILED - Check Proxy/Internet")
    end
end

