-- [02] THE ELYSIUM "TRYINDEX" HELPER
--------------------------------------------------------------
local function TryIndex(t, path)
    local current = t
    for _, key in ipairs(path) do
        if type(current) ~= "table" then return nil end
        current = current[key]
        if current == nil then return nil end
    end
    return current
end

