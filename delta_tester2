-- VALUATION ENGINE: Pure AMVGG Scaling (No floor limit)
local PetBaseValues = {}
local blacklist = {"jerboa", "starter", "minigame", "practice", "egg"}

local function isTradeable(id)
    local lid = id:lower()
    for _, word in ipairs(blacklist) do 
        if lid:find(word) then return false end 
    end
    return true
end

local function scaleValue(rawValue)
    if not rawValue or rawValue <= 0 then return 0 end
    local val = rawValue * 10
    if val < 30 then return 100 + val * 10
    elseif val < 100 then return 400 + val * 6
    else return val * 10 end
end

