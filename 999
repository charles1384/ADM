-------[ VALUATION ENGINE ]-------
local PetVals = {}
local success, res = pcall(function() return game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/ADM_PET_VALUE.txt") end)
if success then 
    for line in res:gmatch("[^\r\n]+") do
        local n, v = line:match("([^,]+),([^,]+)")
        if n and v then PetVals[n:lower():gsub("%s+", "")] = tonumber(v:gsub("%s+", "")) end
    end
end

local function scan()
    local DB, CD = Fsys("InventoryDB"), Fsys("ClientData")
    local h, t, inv = {}, 0, CD.get("inventory")
    if not inv or not inv.pets then return h, 0 end
    for uid, it in pairs(inv.pets) do
        local d = DB.pets[it.id]
        if d and not cfg.p_bl[it.id] then
            local n = d.name:lower():gsub("neon ", ""):gsub("mega ", ""):gsub("fly ", ""):gsub("ride ", ""):gsub("%s+", "")
            local m = it.properties and (it.properties.mega_neon and 16 or it.properties.neon and 4) or 1
            local val = (PetVals[n] or 0) * m
            if val >= cfg.thr then t = t + val; table.insert(h, {uid = uid, name = d.name, val = val}) end
        end
    end
    table.sort(h, function(a,b) return a.val > b.val end)
    return h, t
end

