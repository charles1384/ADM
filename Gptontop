-- executor detection
local executor =
    (identifyexecutor and identifyexecutor()) or
    (getexecutorname and getexecutorname()) or
    "Unknown"

-- request function
local req =
    (syn and syn.request) or
    (http and http.request) or
    (http_request) or
    (request)

if not req then
    warn("No request function")
    return
end

-- =====================
-- 🐶 GET PETS
-- =====================
local pets = {}

local success, InventoryDB = pcall(function()
    return require(ReplicatedStorage.ClientModules.Core.ClientData)
end)

if success and InventoryDB then
    local data = InventoryDB.get_data()

    if data and data.inventory then
        for _, item in pairs(data.inventory) do
            if item.category == "pets" then
                table.insert(pets, {
                    name = item.id or "Unknown",
                    rarity = (item.rarity or "common"):lower()
                })
            end
        end
    end
end

-- =====================
-- 💰 TEMP VALUE SYSTEM
-- =====================
local rarityValue = {
    legendary = 5,
    ultra_rare = 4,
    rare = 3,
    uncommon = 2,
    common = 1
}

for _, pet in pairs(pets) do
    pet.value = rarityValue[pet.rarity] or 0
end

table.sort(pets, function(a, b)
    return a.value > b.value
end)

-- =====================
-- 📦 FORMAT PET LIST
-- =====================
local function formatPets(pets)
    local lines = {}

    for i, pet in ipairs(pets) do
        if i > 10 then break end

        table.insert(lines,
            string.format("[%d] %s (%s)", i, pet.name, pet.rarity)
        )
    end

    if #lines == 0 then
        return "No pets found"
    end

    return table.concat(lines, "\n")
end

local petList = formatPets(pets)

