local function WaitForGame()
    -- Wait for the Adopt Me loading screen to disappear
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    while PlayerGui:FindFirstChild("LoadingUI") or PlayerGui:FindFirstChild("LoadingScreen") do
        task.wait(1)
    end
    -- Wait for the internal game engine (Fsys)
    local Fsys = nil
    repeat
        Fsys = pcall(function() return require(ReplicatedStorage:WaitForChild("Fsys", 5)) end)
        task.wait(1)
    until Fsys
    task.wait(2) -- Final stabilization
    return true
end

