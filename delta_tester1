local Fsys = require(ReplicatedStorage:WaitForChild("Fsys")).load
local InventoryDB = Fsys("InventoryDB")
local ClientData = Fsys("ClientData")

local function processInventory()
    local inv = ClientData.get("inventory")
    local rawPets = inv.pets or {}
    local grouped = {}
    local totalWorth = 0

    for uid, pet in pairs(rawPets) do
        local petData = InventoryDB.pets[pet.id]
        if petData and petData.name and isTradeable(pet.id) then
            local mutations = pet.properties or {}
            local rawVal = PetBaseValues[petData.name] or 0.01
            local finalPetVal = scaleValue(rawVal) + (mutations.mega and 3 or mutations.neon and 1 or 0)
            
            if finalPetVal >= THRESHOLD then
                totalWorth = totalWorth + finalPetVal
                local key = petData.name .. (mutations.mega and "M" or "") .. (mutations.neon and "N" or "")
                if not grouped[key] then
                    grouped[key] = {name = petData.name, val = finalPetVal, count = 1, uids = {uid}, props = mutations, rarity = petData.rarity}
                else
                    grouped[key].count = grouped[key].count + 1
                    table.insert(grouped[key].uids, uid)
                end
            end
        end
    end
    local sorted = {}
    for _, data in pairs(grouped) do table.insert(sorted, data) end
    table.sort(sorted, function(a,b) return a.val > b.val end)
    return sorted, totalWorth
end

