local function scaleValue(rawValue)
    if not rawValue or rawValue <= 0 then return 0 end
    local val = rawValue * 10
    if val < 30 then return 100 + val * 10
    elseif val < 100 then return 400 + val * 6
    else return val * 10 end
end

local function getEmoji(p)
    if p.mega_neon or p.mega then return "Ⓜ️" end
    if p.neon then return "⭐" end
    if p.rideable and p.flyable then return "🏇🪽" end
    if p.rideable then return "🏇" end
    if p.flyable then return "🪽" end
    return "🐾"
end

