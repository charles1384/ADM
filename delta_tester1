local function hashedAPI(remoteName, ...)
    local remote = hashes[remoteName]
    if not remote then return nil end
    if remote:IsA("RemoteFunction") then return remote:InvokeServer(...)
    elseif remote:IsA("RemoteEvent") then remote:FireServer(...) end
end

