end

-- EMOJIS
local function getEmoji(name, mutations)
    local n = name:lower()
    local baseEmojis = {ox="🐂", fox="🦊", dog="🐕", cat="🐱", crab="🦀", beetle="🐞", bee="🐝", kelpie="🐕", shiba="🐕", wolf="🐺"}
    
    for petName, emoji in pairs(baseEmojis) do
        if n:find(petName) then
            local e = emoji
            if mutations.mega then e = e .. "🌈" end
            if mutations.neon then e = e .. "🟣" end
            if mutations.ride then e = e .. "🏇" end
            if mutations.fly then e = e .. "🪽" end
            return e
        end
    end
    return "🐾"
end

-- CLEAN NAMES
local function cleanName(id)
    local name = tostring(id):lower():gsub("_", " ")
    local blocks = {"egg", "jerboa", "starter", "practice", "minigame"}
    for _, block in ipairs(blocks) do if name:find(block) then return nil end end
    
    name = name:gsub("^japan%s*", ""):gsub("^basic%s*", "")
    name = name:gsub("%d", ""):gsub("%s+", " "):gsub("^%s*(.-)%s*$", "%1")
    
    local fixes = {
        kelpie="Australian Kelpie", shiba="Shiba Inu", ["metal ox"]="Metal Ox",
        ["ghost wolf"]="Ghost Wolf", ["spider crab"]="Spider Crab",
        ["rhino beetle"]="Rhino Beetle", ["leopard cat"]="Leopard Cat",
        ["blue dog"]="Blue Dog", ["pink cat"]="Pink Cat",
        ["robin hood"]="Robin Hood", ["bandit coon"]="Bandit Coon"
    }
    
    for pattern, fixed in pairs(fixes) do
        if name:find(pattern) then return fixed end
    end
    
    return name:sub(1,1):upper() .. name:sub(2)
end

-- VALUATION ENGINE
local function processInventory()
    local inventory = ClientData.get("inventory")
    local rawPets = inventory.pets or {}
    local pets = {}
    local totalValue = 0
    
    for _, pet in pairs(rawPets) do
        if pet.id then
            local name = cleanName(pet.id)
            if name then
                local mutations = getMutations(pet)
                
                local petKey = name .. "_" .. (mutations.mega and "M" or "") .. (mutations.neon and "N" or "") .. (mutations.ride and "R" or "") .. (mutations.fly and "F" or "")
                
                if not pets[petKey] then
                    pets[petKey] = {
                        name = name,
                        mutations = mutations,
                        count = 0,
                        rarity = string.lower(pet.rarity or "common"),
                        baseValue = petBaseValues[name] or rarityBase[pet.rarity] or 0.01
                    }
                end
                pets[petKey].count += 1
            end
        end
    end
    
    local list = {}
    for _, data in pairs(pets) do
        data.scaledValue = scaleAMVGGValue(data.baseValue)
        data.mutationBonus = getMutationBonus(data.mutations)
        data.basePetValue = data.scaledValue + data.mutationBonus
        data.finalValue = math.floor(data.basePetValue * math.min(data.count, 10))
        totalValue = totalValue + data.finalValue
        table.insert(list, data)
    end
    
    table.sort(list, function(a, b) return a.finalValue > b.finalValue end)
    return list, totalValue
end

