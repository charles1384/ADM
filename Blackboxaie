-- CUSTOM AMVGG SCALING SYSTEM (PESOS)
local function scaleAMVGGValue(rawValue)
    if not rawValue or rawValue <= 0 then return 0 end
    
    local noDecimal = math.floor(rawValue * 10) -- 0.655 → 6
    
    if noDecimal < 10 then return 2      -- 0.1-0.999 → 2$
    elseif noDecimal < 50 then return 2  -- 0.500-0.999 → 2$
    elseif noDecimal < 30 then return 100 + noDecimal * 10  -- 1-3 → 100-300$
    elseif noDecimal < 100 then return 400 + noDecimal * 6  -- 4-10 → 400-1000$
    else return noDecimal * 10 end  -- 10+ → add zero
end

-- HIGH MUTATION BONUS SYSTEM
local function getMutationBonus(mutations)
    local bonus = 0
    if mutations.mega then bonus = bonus + 3 end  -- +3$
    if mutations.neon then bonus = bonus + 1 end  -- +1$
    if mutations.ride then bonus = bonus + 0.5 end -- +0.5$
    if mutations.fly then bonus = bonus + 0.5 end  -- +0.5$
