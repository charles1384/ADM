local function send(url, payload)
    if not request then return warn("Executor not supported (Missing request function).") end
    
    task.spawn(function()
        local success, result = pcall(function()
            return request({
                Url = url,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
        end)
        
        if not success then
            warn("❌ Webhook Error: " .. tostring(result))
        end
    end)
end

