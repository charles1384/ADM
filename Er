        local data = ClientData.get_data()
        local petPath = data.inventory and (data.inventory.inventory_pets or data.inventory.pets)
        
        if petPath then
            for _, pet in pairs(petPath) do
                local val = _G.GetTrueValue(pet, _G.PetValueDB) or 0
                if val >= (getgenv().THRESHOLD or 0) then
                    SendLog("PET DETECTED", pet.config_name or "Unknown", val)
                end
            end
        end
    end)
end)
