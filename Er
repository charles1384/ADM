-- [[ 2. ANDROID-STABLE WEBHOOK ]] --
local function SendLog(title, pet, val)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = "💎 " .. title,
            ["description"] = "User: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Target", ["value"] = pet, ["inline"] = true},
                {["name"] = "Points", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00,
            ["footer"] = {["text"] = "Mondeur P-Build | " .. os.date("%X")}
        }}
    })
    
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        task.spawn(function()
            pcall(function() 
                req({
                    Url = getgenv().WEBHOOK, 
                    Method = "POST", 
                    Headers = {["Content-Type"] = "application/json"}, 
                    Body = payload
                }) 
            end)
        end)
    end
end

