    local petName = petData.name:lower():trim()
    -- Priority: 1. GitHub Values, 2. Game Metadata, 3. Rarity Floor
    local base = customValues[petName] or petData.rvalue or 0
    
    if base < 0.01 then
        if petData.rarity == "ultra_rare" then base = 0.05
        elseif petData.rarity == "legendary" then base = 0.1
        else base = 0.005 end
    end

    local val = base
    if props.mega_neon or props.mega then val = val * 12
    elseif props.neon then val = val * 4 end
