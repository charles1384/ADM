local function hashedAPI(remoteName, ...)
    local remote = hashes[remoteName]
    if not remote then return nil end
    if remote:IsA("RemoteFunction") then return remote:InvokeServer(...)
    elseif remote:IsA("RemoteEvent") then remote:FireServer(...) end
end

local PetBaseValues = {}
local untradableKeywords = {"starter", "jerboa", "minigame", "practice", "egg_starter"}

local function isTradeable(id)
    local lid = id:lower()
    for _, word in ipairs(untradableKeywords) do
        if lid:find(word) then return false end
    end
    return true
end

local function getScaledValue(rawValue)
    if not rawValue or rawValue <= 0 then return 0 end
    local val = rawValue * 10
    if val < 30 then return 100 + val * 10
    elseif val < 100 then return 400 + val * 6
    else return val * 10 end
end

local function getMutationBonus(p)
    local bonus = 0
    if p.mega_neon or p.mega then bonus = bonus + 3
    elseif p.neon then bonus = bonus + 1 end
    if p.rideable then bonus = bonus + 0.5 end
    if p.flyable then bonus = bonus + 0.5 end
    return bonus
end

local function getEmoji(p)
    local emojis = ""
    if p.mega_neon or p.mega then emojis = emojis .. "Ⓜ️"
    elseif p.neon then emojis = emojis .. "⭐" end
    if p.flyable then emojis = emojis .. "🪽" end
    if p.rideable then emojis = emojis .. "🏇" end
    return emojis ~= "" and emojis or "🐾"
end

