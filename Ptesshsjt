-- [[ 2. ANDROID-STABLE WEBHOOK ]] --
local function SendLog(title, pet, val)
    local url = getgenv().WEBHOOK
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = "User: **" .. LocalPlayer.Name .. "**",
            ["fields"] = {
                {["name"] = "Pet", ["value"] = pet, ["inline"] = true},
                {["name"] = "Points", ["value"] = tostring(val), ["inline"] = true}
            },
            ["color"] = 0x00FF00
        }}
    }
    
    -- Force-detect the correct request function for Android
    local request = (syn and syn.request) or (http and http.request) or http_request or request
    if request then
        pcall(function()
            request({
                Url = url,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end
end

-- [[ 3. DELAYED DEEP SCAN ]] --
task.spawn(function()
    task.wait(5) -- Wait 5 seconds to bypass game-load lag
    SendLog("📡 CONNECTION TEST", "Success", 0)

    local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
