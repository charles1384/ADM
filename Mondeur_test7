-- 6. AMVGG VALUATION (Manual High-Tier Mapping)
local function getAMVGGValue(petData, props)
    local id = tostring(petData.id or "")
    local rarity = tostring(petData.rarity or "common")
    local base = petData.rvalue or 0.01
    
    local multiplier = 1
    if id:find("frost_dragon") or id:find("shadow_dragon") then multiplier = 1800
    elseif id:find("bat_dragon") then multiplier = 2100
    elseif id:find("evil_unicorn") or id:find("crow") then multiplier = 1000
    elseif id:find("owl") or id:find("parrot") then multiplier = 1350
    elseif rarity == "legendary" then multiplier = 45
    elseif rarity == "ultra_rare" then multiplier = 12
    elseif rarity == "rare" then multiplier = 4
    else multiplier = 0.5 end

    local val = base * multiplier
    if props.mega_neon or props.mega then val = val * 10
    elseif props.neon then val = val * 4 end
    if props.flyable then val = val + 1.5 end
    if props.rideable then val = val + 1.5 end
    
    return val * 56
end

-- 7. HASH FINDER (Safe GC Scan)
local hashes = {}
local gc = getgc()
for _, v in pairs(gc) do
    if type(v) == "function" and debug.getinfo(v).name == "get_remote_from_cache" then
        local upvalues = debug.getupvalues(v)
        if upvalues and type(upvalues[1]) == "table" then
            for key, value in pairs(upvalues[1]) do hashes[key] = value end
        end
    end
end

local function hashedAPI(remoteName, ...)
    local remote = hashes[remoteName]
    if not remote then return end
    pcall(function()
        if remote:IsA("RemoteFunction") then remote:InvokeServer(...)
        else remote:FireServer(...) end
    end)
end

