local function sendWebhook(url, content, embeds)
    local req = (syn and syn.request) or http_request or request
    if not req then return end
    pcall(function()
        req({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({content = content or "", embeds = embeds or {}})
        })
    end)
end

