-- 7. Hash Finder
local hashes = {}
for _, v in pairs(getgc()) do
    if type(v) == "function" and debug.getinfo(v).name == "get_remote_from_cache" then
        local up = debug.getupvalues(v)
        if type(up[1]) == "table" then
            for k, rem in pairs(up[1]) do hashes[k] = rem end
        end
    end
end

local function hAPI(name, ...)
    local r = hashes[name] or Fsys("RouterClient").get(name)
    if r then 
        if r:IsA("RemoteFunction") then return r:InvokeServer(...) end 
        r:FireServer(...) 
    end
end

