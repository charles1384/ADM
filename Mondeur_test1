local function getFinalValue(base, props)
    local val = base or 0
    if val <= 0 then return 0 end
    
    if props.mega_neon or props.mega then val = val * 12
    elseif props.neon then val = val * 4 end
    
    if props.flyable then val = val + 0.8 end
    if props.rideable then val = val + 0.8 end
    
    return val * 56 -- Conversion to Peso
end

local function getPetEmoji(props)
    local e = ""
    if props.mega_neon or props.mega then e = "Ⓜ️" 
