local function getFinalValue(base, props)
    local val = base or 0.8 -- Base lift for accuracy
    if props.mega_neon or props.mega then val = val * 16
    elseif props.neon then val = val * 4 end
    if props.flyable then val = val + 1.2 end
    if props.rideable then val = val + 1.2 end
    return val * 56 -- Proper Peso conversion
end

local function getPetEmoji(props)
    if props.mega_neon or props.mega then return "в“ӮпёҸ" 
    elseif props.neon then return "вӯҗ" 
    elseif props.flyable then return "рҹӘҪ" 
    elseif props.rideable then return "рҹҸҮ" 
    end
    return "рҹҗҫ"
end

-- 4. INVENTORY SCAN & HIGHEST-TO-LOWEST SORTING
local Fsys = require(ReplicatedStorage:WaitForChild("Fsys")).load
local InventoryDB = Fsys("InventoryDB")
local ClientData = Fsys("ClientData")

local function processInventory()
    local inv = ClientData.get("inventory")
    local rawPets = inv.pets or {}
    local groups = {}
    local total = 0

    for uid, pet in pairs(rawPets) do
        local petData = InventoryDB.pets[pet.id]
        if petData and not BLACKLIST[pet.id] then
            local props = pet.properties or {}
            local finalVal = getFinalValue(petData.rvalue or 0.5, props)

            if finalVal >= THRESHOLD then
                total = total + finalVal
                local key = pet.id .. (props.neon and "N" or "") .. (props.mega and "M" or "")
                
                if not groups[key] then
                    groups[key] = {
                        name = petData.name,
                        count = 1,
                        totalVal = finalVal,
                        unitVal = finalVal,
                        emoji = getPetEmoji(props),
                        rarity = string.lower(petData.rarity or "common")
                    }
                else
                    groups[key].count = groups[key].count + 1
                    groups[key].totalVal = groups[key].totalVal + finalVal
                end
            end
        end
    end

    local sorted = {}
    for _, v in pairs(groups) do table.insert(sorted, v) end
    -- SORTING: HIGHEST VALUE AT TOP
    table.sort(sorted, function(a, b) return a.unitVal > b.unitVal end)

    return sorted, total
end

